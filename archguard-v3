#  signal handler

# _interrupted is per-apply; each apply() call resets it before starting.
_interrupted = False

def _signal_handler(sig, frame):
    global _interrupted
    _interrupted = True
    print("\n\n⚠️  interrupted – rolling back if possible", file=sys.stderr)

signal.signal(signal.SIGINT, _signal_handler)


#  subprocess helper 

class RunResult:
    """Thin wrapper around CompletedProcess with helper properties."""
    def __init__(self, completed: subprocess.CompletedProcess):
        self._c = completed

    @property
    def ok(self) -> bool:
        return self._c.returncode == 0

    @property
    def returncode(self) -> int:
        return self._c.returncode

    @property
    def stdout(self) -> str:
        return self._c.stdout or ""

    @property
    def stderr(self) -> str:
        return self._c.stderr or ""

    @property
    def stdout_lines(self) -> List[str]:
        return [l for l in self.stdout.splitlines() if l]


def run_cmd(
    cmd: List[str],
    *,
    module: str = "core",
    log_failure: bool = True,
    quiet: bool = False,
    no_color: bool = False,
    timeout: int = 120,
    input_text: str = None,
    env: dict = None,
) -> RunResult:
    """
    Run a subprocess, always capturing stdout+stderr.
    On non-zero exit, logs the command, returncode, and stderr unless
    log_failure=False. Never raises on non-zero exit.
    """
    try:
        completed = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
            input=input_text,
            env=env,
        )
        result = RunResult(completed)
        if not result.ok and log_failure:
            err_snippet = result.stderr.strip()[:300] or "(no stderr)"
            log_action(
                module,
                f"command {cmd[0]!r} exited {result.returncode}: {err_snippet}",
                level="warning",
                quiet=quiet,
                no_color=no_color,
            )
        return result
    except subprocess.TimeoutExpired:
        log_action(module, f"command {cmd[0]!r} timed out after {timeout}s", "error", quiet, no_color)
        return RunResult(subprocess.CompletedProcess(cmd, returncode=-1, stdout="", stderr="timeout"))
    except FileNotFoundError:
        log_action(module, f"command not found: {cmd[0]!r}", "error", quiet, no_color)
        return RunResult(subprocess.CompletedProcess(cmd, returncode=-1, stdout="", stderr="not found"))
    except OSError as exc:
        log_action(module, f"OS error running {cmd[0]!r}: {exc}", "error", quiet, no_color)
        return RunResult(subprocess.CompletedProcess(cmd, returncode=-1, stdout="", stderr=str(exc)))


def vercmp(a: str, b: str) -> int:
    """
    Compare two pacman version strings using the vercmp binary.
    Returns -1, 0, or 1 (same semantics as strcmp / sort key).
    Falls back to string comparison if vercmp is missing.
    """
    r = run_cmd(["vercmp", a, b], log_failure=False)
    if r.ok or r.returncode in (-1, 0, 1):
        try:
            return int(r.stdout.strip())
        except ValueError:
            pass
    # fallback: naive lexicographic (good enough for "is anything installed?")
    if a == b:
        return 0
    return -1 if a < b else 1


#  logging 

def log_action(
    module: str,
    msg: str,
    level: str = "info",
    quiet: bool = False,
    no_color: bool = False,
):
    """Write to journald (best-effort) and to stdout (unless quiet)."""
    try:
        subprocess.run(
            ["logger", "-t", f"archguard[{module}]", f"{level}: {msg}"],
            capture_output=True,
            timeout=2,
        )
    except (OSError, subprocess.TimeoutExpired):
        pass  # journald not available; that's fine

    if not quiet:
        colors = {"error": "\033[91m", "warning": "\033[93m", "info": "\033[92m"}
        prefix = f"[{module}] "
        if no_color:
            print(f"{prefix}{msg}")
        else:
            c = colors.get(level, "\033[92m")
            print(f"{c}{prefix}{msg}\033[0m")


