#  cache helpers 

CACHE_DIR = Path("/var/cache/archguard")

def cache_get(key: str, ttl_seconds: int = 3600) -> Optional[str]:
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    p = CACHE_DIR / (re.sub(r"[^a-z0-9_-]", "_", key) + ".cache")
    if not p.exists():
        return None
    age = time.time() - p.stat().st_mtime
    if age > ttl_seconds:
        return None
    try:
        return p.read_text()
    except OSError:
        return None

def cache_put(key: str, value: str):
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    p = CACHE_DIR / (re.sub(r"[^a-z0-9_-]", "_", key) + ".cache")
    try:
        p.write_text(value)
    except OSError as exc:
        _log.warning("cache write failed for %s: %s", key, exc)



#THE  BASE MODULE


class Module:
    info = ModInfo(
        name="base", kind=ModKind.AUDIT, desc="base – should not appear",
        version="3.0.0", author="archguard", deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def __init__(self, state: State, quiet=False, verbose=False, no_color=False):
        self.state    = state
        self.backups  = BackupKeeper(state)
        self.quiet    = quiet
        self.verbose  = verbose
        self.no_color = no_color
        self._pre_checked = False
        self.findings: List[Finding] = []

    #  dependency or check for conflicts

    def pre_check(self, force=False, install_deps=False) -> Tuple[bool, str]:
        missing = []
        for pkg in self.info.deps:
            r = run_cmd(["pacman", "-Q", pkg], log_failure=False)
            if not r.ok:
                missing.append(pkg)

        if missing:
            if install_deps:
                log_action(self.info.name, f"installing: {', '.join(missing)}", quiet=self.quiet, no_color=self.no_color)
                for pkg in missing:
                    r = run_cmd(["pacman", "-S", "--noconfirm", pkg],
                                module=self.info.name, quiet=self.quiet, no_color=self.no_color, timeout=300)
                    if not r.ok:
                        return False, f"failed to install '{pkg}': {r.stderr.strip()[:200]}"
            else:
                return False, f"missing deps: {', '.join(missing)} (use --install-deps)"

        for pkg in self.info.conflicts:
            r = run_cmd(["pacman", "-Q", pkg], log_failure=False)
            if r.ok:
                if not force:
                    return False, f"conflicting package '{pkg}' installed (use --force)"
                log_action(self.info.name, f"conflicting package '{pkg}' present – continuing (--force)", "warning", self.quiet, self.no_color)

        self._pre_checked = True
        return True, "ok"

    #  config generation (override in hardening modules) 

    def gen_config(self, **kwargs) -> Dict[str, str]:
        return {}

    #  apply: write configs with backup / rollback

    def apply(self, dry=False, force=False, verify=False, **kw) -> Tuple[bool, str]:
        global _interrupted
        _interrupted = False          # reset per-apply so preset runs don't bleed

        if _interrupted:
            return False, "interrupted before starting"

        if not dry:
            ok, msg = self.pre_check(force, kw.get("install_deps", False))
            if not ok:
                return False, f"pre-check failed: {msg}"

        configs = self.gen_config(**kw)
        if not configs:
            return True, "nothing to do"

        applied: List[Tuple[str, Optional[str], bool]] = []
        changed = False

        for path, new_content in configs.items():
            if _interrupted:
                log_action(self.info.name, "interrupted – rolling back", "warning", self.quiet, self.no_color)
                self._rollback_changes(applied)
                return False, "interrupted"

            p = Path(path)
            old_content = ""
            if p.exists():
                try:
                    old_content = p.read_text()
                except OSError as exc:
                    log_action(self.info.name, f"cannot read {path}: {exc}", "warning", self.quiet, self.no_color)
                    continue

            if old_content == new_content:
                continue

            changed = True
            show_diff(old_content, new_content, path, self.verbose, self.no_color)

            if dry:
                continue

            if not force:
                try:
                    resp = input(f"apply changes to {path}? [y/N] ")
                except EOFError:
                    resp = "n"
                if resp.strip().lower() != "y":
                    continue

            backup_path: Optional[str] = None
            is_new = False
            if p.exists():
                b = self.backups.create(path, self.info.name)
                if b:
                    backup_path = str(b)
                    log_action(self.info.name, f"backup → {b}", quiet=self.quiet, no_color=self.no_color)
                else:
                    log_action(self.info.name, f"backup failed for {path} – skipping write", "error", self.quiet, self.no_color)
                    self._rollback_changes(applied)
                    return False, f"backup failed for {path}"
            else:
                self.state.add(self.info.name, path, "NEW_FILE")
                is_new = True

            if not atomic_write(p, new_content, Path(backup_path) if backup_path else None, self.no_color):
                log_action(self.info.name, f"write failed: {path}", "error", self.quiet, self.no_color)
                self._rollback_changes(applied)
                return False, f"write failed for {path}"

            log_action(self.info.name, f"applied {path}", quiet=self.quiet, no_color=self.no_color)
            applied.append((path, backup_path, is_new))

        if not changed:
            return True, "already up-to-date"

        if verify and not dry:
            ok, vmsg = self.verify()
            level = "info" if ok else "warning"
            log_action(self.info.name, f"verify: {vmsg}", level, self.quiet, self.no_color)

        return True, "module applied"

    def _rollback_changes(self, changes: List[Tuple[str, Optional[str], bool]]):
        for path, backup_path, is_new in reversed(changes):
            if is_new:
                try:
                    Path(path).unlink(missing_ok=True)
                    log_action(self.info.name, f"rollback: removed {path}", quiet=self.quiet, no_color=self.no_color)
                    self.state.remove(self.info.name, path, "NEW_FILE")
                except OSError as exc:
                    log_action(self.info.name, f"rollback: could not remove {path}: {exc}", "error", self.quiet, self.no_color)
            elif backup_path:
                bp = Path(backup_path)
                if bp.exists():
                    self.backups.restore(path, bp)
                    log_action(self.info.name, f"rollback: restored {path}", quiet=self.quiet, no_color=self.no_color)
                    self.state.remove(self.info.name, path, backup_path)
                else:
                    log_action(self.info.name, f"rollback: backup missing for {path}", "error", self.quiet, self.no_color)

    def revert(self) -> Tuple[bool, str]:
        if not self.info.reversible:
            return False, "module is not reversible"
        changes = self.state.get(self.info.name)
        if not changes:
            return False, "no recorded changes"

        reverted = 0
        for rec in sorted(changes, key=lambda r: r["when"], reverse=True):
            path, backup = rec["path"], rec["backup"]
            if backup == "NEW_FILE":
                try:
                    Path(path).unlink(missing_ok=True)
                    log_action(self.info.name, f"removed {path}", quiet=self.quiet, no_color=self.no_color)
                    reverted += 1
                    self.state.remove(self.info.name, path, backup)
                except OSError as exc:
                    log_action(self.info.name, f"failed to remove {path}: {exc}", "error", self.quiet, self.no_color)
            else:
                bp = Path(backup)
                if not bp.exists():
                    log_action(self.info.name, f"backup missing: {bp}", "error", self.quiet, self.no_color)
                    continue
                if self.backups.restore(path, bp, rec.get("checksum", "")):
                    log_action(self.info.name, f"restored {path}", quiet=self.quiet, no_color=self.no_color)
                    reverted += 1
                    self.state.remove(self.info.name, path, backup)
                else:
                    log_action(self.info.name, f"restore failed for {path}", "error", self.quiet, self.no_color)

        return (True, f"reverted {reverted} change(s)") if reverted else (False, "nothing reverted")

    def status(self) -> ModStatus:
        return ModStatus.UNKNOWN

    def verify(self) -> Tuple[bool, str]:
        return True, "ok"

    def emit(self, severity: str, title: str, detail: str = "", remediation: str = ""):
        """Record a finding from an audit module."""
        f = Finding(severity=severity, module=self.info.name, title=title, detail=detail, remediation=remediation)
        self.findings.append(f)
        if not self.quiet:
            icons = {"critical": "🔴", "warning": "🟡", "info": "🔵"}
            icon = icons.get(severity, "•") if not self.no_color else f"[{severity.upper()}]"
            print(f"  {icon} {title}")
            if self.verbose and detail:
                for line in detail.splitlines():
                    print(f"      {line}")
        return f


