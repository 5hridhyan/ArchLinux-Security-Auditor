class LogAudit(Module):
    info = ModInfo(
        name="log_audit", kind=ModKind.AUDIT,
        desc="Scan journal for failed logins, sudo failures, service crashes",
        version="3.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def _journal_grep(self, pattern: str, since: str = "24 hours ago") -> List[str]:
        """
        Use journalctl -g (--grep) which is the correct way to filter by message
        content. Falls back to piping through grep if journalctl is too old.
        """
        # Try journalctl --grep first (systemd ≥ 249)
        r = run_cmd(
            ["journalctl", "-q", "--since", since, "--grep", pattern, "--no-pager"],
            log_failure=False, timeout=30,
        )
        if r.returncode == 0 or (r.returncode == 1 and not r.stderr.strip()):
            # returncode 1 with no stderr = no matches (normal)
            return r.stdout_lines

        # Fallback: pipe journalctl into grep
        jctl = run_cmd(["journalctl", "-q", "--since", since, "--no-pager"], log_failure=False, timeout=30)
        return [l for l in jctl.stdout_lines if re.search(pattern, l, re.IGNORECASE)]

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            log_action(self.info.name, "dry run: would scan journal for last 24h", quiet=self.quiet, no_color=self.no_color)
            return True, "dry run"

        checks = [
            ("sudo.*authentication failure",  "failed sudo attempts",    "warning"),
            ("sshd.*Failed password",         "failed SSH logins",       "warning"),
            ("sshd.*Invalid user",            "SSH invalid user probes", "warning"),
            (r"unit.*entered failed state",   "service failures",        "warning"),
            ("OUT OF MEMORY|OOM killer",      "OOM kills",               "warning"),
            ("segfault",                      "segfaults",               "info"),
            ("kernel: BUG",                   "kernel BUGs",             "critical"),
            ("Accepted publickey",            "SSH public-key logins",   "info"),
        ]

        all_output: List[str] = []
        for pattern, label, severity in checks:
            lines = self._journal_grep(pattern)
            all_output.extend(lines)
            if lines:
                detail = "\n".join(lines[:10]) + (f"\n…and {len(lines)-10} more" if len(lines) > 10 else "")
                self.emit(severity, f"{len(lines)} {label} in last 24h", detail)
            else:
                self.emit("info", f"no {label}")

        save_report("log_audit", "\n".join(all_output))
        self.state.save_findings(self.findings)
        return True, "log audit completed"

    def status(self): return ModStatus.UNKNOWN


class SSHAudit(Module):
    info = ModInfo(
        name="ssh_audit", kind=ModKind.AUDIT,
        desc="Audit sshd_config for weak settings (root login, password auth, etc.)",
        version="3.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            log_action(self.info.name, "dry run: would check /etc/ssh/sshd_config", quiet=self.quiet, no_color=self.no_color)
            return True, "dry run"

        sshd_conf = Path("/etc/ssh/sshd_config")
        if not sshd_conf.exists():
            self.emit("info", "sshd_config not found – SSH not installed")
            return True, "ssh not installed"

        try:
            conf = sshd_conf.read_text()
        except OSError as exc:
            return False, f"cannot read sshd_config: {exc}"

        def get_val(key: str) -> Optional[str]:
            m = re.search(rf"^\s*{key}\s+(\S+)", conf, re.IGNORECASE | re.MULTILINE)
            return m.group(1).lower() if m else None

        checks = [
            ("PermitRootLogin",      lambda v: v in ("no", "prohibit-password"),
             "PermitRootLogin should be 'no' or 'prohibit-password'",
             "warning", "Set 'PermitRootLogin no' in sshd_config"),
            ("PasswordAuthentication", lambda v: v == "no",
             "PasswordAuthentication should be 'no' (use keys)",
             "warning", "Set 'PasswordAuthentication no' in sshd_config"),
            ("PermitEmptyPasswords", lambda v: v == "no",
             "PermitEmptyPasswords should be 'no'",
             "critical", "Set 'PermitEmptyPasswords no' in sshd_config"),
            ("Protocol",             lambda v: v == "2",
             "SSH Protocol should be 2 (legacy setting; absence is fine on modern sshd)",
             "info", "Remove Protocol line or set to 2"),
            ("X11Forwarding",        lambda v: v == "no",
             "X11Forwarding should be disabled",
             "info", "Set 'X11Forwarding no' in sshd_config"),
            ("MaxAuthTries",         lambda v: int(v) <= 4 if v and v.isdigit() else False,
             "MaxAuthTries should be ≤ 4",
             "warning", "Set 'MaxAuthTries 3' in sshd_config"),
        ]

        for key, test, msg, severity, remediation in checks:
            val = get_val(key)
            if val is None:
                self.emit("info", f"{key} not explicitly set (using default)")
            elif test(val):
                self.emit("info", f"{key} = {val} ✓")
            else:
                self.emit(severity, f"{key} = {val} – {msg}", remediation=remediation)

        # Check for weak ciphers
        weak = ["arcfour", "des", "3des", "blowfish", "cast128"]
        ciphers_line = get_val("Ciphers")
        if ciphers_line and any(w in ciphers_line for w in weak):
            self.emit("critical", "Weak SSH ciphers in Ciphers directive",
                      ciphers_line,
                      "Remove weak ciphers from sshd_config Ciphers line")

        save_report("ssh_audit", "\n".join(f.title for f in self.findings))
        self.state.save_findings(self.findings)
        return True, "SSH audit completed"

    def status(self): return ModStatus.UNKNOWN


