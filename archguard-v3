    info = ModInfo(
        name="aide", kind=ModKind.INTEGRITY,
        desc="AIDE file integrity checker – init database or run check",
        version="3.0.0", author="archguard",
        deps=["aide"], conflicts=[],
        reversible=True, risk="medium",
    )

    _CONF = """\
# AIDE config – archguard
database=file:/var/lib/aide/aide.db.gz
database_out=file:/var/lib/aide/aide.db.new.gz
verbose=5
report_url=file:/var/log/archguard/aide.log

NORMAL = sha256+rmd160+size+mtime+ctime+acl+xattrs
/boot     NORMAL
/bin      NORMAL
/sbin     NORMAL
/lib      NORMAL
/lib64    NORMAL
/usr      NORMAL
/root     NORMAL
/etc      NORMAL
!/var/log
!/proc
!/sys
!/dev
!/run
!/tmp
!/var/cache
"""

    def gen_config(self, **_):
        return {"/etc/aide/aide.conf": self._CONF}

    def apply(self, dry=False, force=False, verify=False, **kw):
        ok, msg = super().apply(dry, force, verify, **kw)
        if not ok or dry: return ok, msg

        db = Path("/var/lib/aide/aide.db.gz")
        db_new = Path("/var/lib/aide/aide.db.new.gz")

        if not db.exists():
            log_action(self.info.name, "initialising AIDE database (may take several minutes)…", quiet=self.quiet, no_color=self.no_color)
            r = run_cmd(["aide", "--init"], module=self.info.name, quiet=self.quiet, no_color=self.no_color, timeout=1200)
            if not r.ok:
                return False, f"aide --init failed: {r.stderr.strip()[:200]}"
            if not db_new.exists():
                return False, "aide --init completed but output database not found"
            try:
                shutil.move(str(db_new), str(db))
            except (OSError, shutil.Error) as exc:
                return False, f"could not move AIDE database: {exc}"
            log_action(self.info.name, "AIDE database initialised", quiet=self.quiet, no_color=self.no_color)
        else:
            log_action(self.info.name, "AIDE database already exists – run 'archguard audit aide' to check integrity", quiet=self.quiet, no_color=self.no_color)

        return True, "aide configured"

    def verify(self):
        r = run_cmd(["aide", "--check"], module=self.info.name, quiet=self.quiet, no_color=self.no_color, timeout=1200)
        output = r.stdout + r.stderr
        save_report("aide", output)
        changes = [l for l in output.splitlines() if any(k in l for k in ("changed", "added", "removed"))]
        if changes:
            for c in changes[:20]:
                self.emit("warning", c.strip(), remediation="Review and update AIDE database if intentional: aide --update")
            self.state.save_findings(self.findings)
            return False, f"{len(changes)} changes detected"
        return True, "integrity ok"

    def status(self): return ModStatus.APPLIED if Path("/var/lib/aide/aide.db.gz").exists() else ModStatus.UNKNOWN


