        if dry:
            log_action(self.info.name, "dry run: would read /etc/sudoers", quiet=self.quiet, no_color=self.no_color)
            return True, "dry run"

        sudoers_files: List[Path] = [Path("/etc/sudoers")]
        sudoers_d = Path("/etc/sudoers.d")
        if sudoers_d.is_dir():
            sudoers_files += list(sudoers_d.iterdir())

        all_lines: List[str] = []
        for sf in sudoers_files:
            if not sf.is_file():
                continue
            try:
                all_lines += sf.read_text().splitlines()
            except OSError as exc:
                log_action(self.info.name, f"cannot read {sf}: {exc}", "warning", self.quiet, self.no_color)

        for line in all_lines:
            stripped = line.strip()
            if stripped.startswith("#") or not stripped:
                continue
            if "NOPASSWD" in stripped:
                self.emit("warning", f"NOPASSWD rule: {stripped}",
                          remediation="Remove NOPASSWD or restrict to specific commands")
            if re.search(r"ALL\s*=\s*\(ALL", stripped) and "NOPASSWD" in stripped:
                self.emit("critical", f"Unrestricted NOPASSWD ALL: {stripped}",
                          remediation="This grants root without password – remove immediately")
            if re.search(r"/bin/(sh|bash|zsh|fish|dash)", stripped):
                self.emit("warning", f"Shell in sudoers (potential escape): {stripped}",
                          remediation="Avoid giving sudo access to shells")

        save_report("sudo_audit", "\n".join(f.title for f in self.findings))
        self.state.save_findings(self.findings)
        return True, "sudoers audit completed"

    def status(self): return ModStatus.UNKNOWN


class WorldWritableAudit(Module):
    info = ModInfo(
        name="world_writable", kind=ModKind.FILESYSTEM,
        desc="Find world-writable files and directories outside /tmp",
        version="3.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            log_action(self.info.name, "dry run: would find world-writable files", quiet=self.quiet, no_color=self.no_color)
            return True, "dry run"

        log_action(self.info.name, "scanning for world-writable files (may take a moment)…", quiet=self.quiet, no_color=self.no_color)
        r = run_cmd(
            ["find", "/", "-xdev", "-type", "f", "-perm", "-0002",
             "!", "-path", "/tmp/*", "!", "-path", "/var/tmp/*",
             "!", "-path", "/proc/*", "!", "-path", "/sys/*"],
            module=self.info.name, log_failure=False, timeout=120,
        )
        files = r.stdout_lines
        for f in files[:50]:
            self.emit("warning", f"world-writable file: {f}",
                      remediation=f"chmod o-w {f}")
        if len(files) > 50:
            self.emit("warning", f"…{len(files)-50} more world-writable files – see report")

        # World-writable directories (outside /tmp) are especially risky
        rd = run_cmd(
            ["find", "/", "-xdev", "-type", "d", "-perm", "-0002",
             "!", "-path", "/tmp", "!", "-path", "/var/tmp",
             "!", "-path", "/proc/*", "!", "-path", "/sys/*"],
            log_failure=False, timeout=120,
        )
        dirs = rd.stdout_lines
        for d in dirs:
            self.emit("critical", f"world-writable directory: {d}",
                      remediation=f"chmod o-w {d}")

        save_report("world_writable", "\n".join(files + dirs))
        self.state.save_findings(self.findings)
        return True, f"{len(files)} files, {len(dirs)} dirs found"

    def status(self): return ModStatus.UNKNOWN


class SuidAudit(Module):
    info = ModInfo(
        name="suid_audit", kind=ModKind.FILESYSTEM,
        desc="Enumerate SUID/SGID binaries and flag unexpected ones",
        version="3.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    # Known-good SUID binaries on a typical Arch system
    EXPECTED_SUID = {
        "/usr/bin/su", "/usr/bin/sudo", "/usr/bin/passwd", "/usr/bin/chfn",
        "/usr/bin/chsh", "/usr/bin/newgrp", "/usr/bin/gpasswd",
        "/usr/bin/pkexec", "/usr/bin/mount", "/usr/bin/umount",
        "/usr/lib/polkit-1/polkit-agent-helper-1",
        "/usr/lib/Xorg.wrap",
        "/usr/bin/fusermount", "/usr/bin/fusermount3",
        "/usr/bin/ping",
    }

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            log_action(self.info.name, "dry run: would enumerate SUID/SGID binaries", quiet=self.quiet, no_color=self.no_color)
            return True, "dry run"

        r = run_cmd(
            ["find", "/usr", "/bin", "/sbin", "/opt", "-xdev",
             "-perm", "/6000", "-type", "f"],
            log_failure=False, timeout=60,
        )
        found = r.stdout_lines

        unexpected = [f for f in found if f not in self.EXPECTED_SUID]
        expected_present = [f for f in found if f in self.EXPECTED_SUID]

        self.emit("info", f"{len(expected_present)} expected SUID/SGID binaries present")
        for b in unexpected:
            self.emit("warning", f"unexpected SUID/SGID binary: {b}",
                      remediation=f"chmod u-s {b}  # if not needed")

        save_report("suid_audit", "\n".join(found))
        self.state.save_findings(self.findings)
        return True, f"{len(found)} SUID/SGID binaries ({len(unexpected)} unexpected)"

    def status(self): return ModStatus.UNKNOWN


class CronAudit(Module):
    info = ModInfo(
        name="cron_audit", kind=ModKind.AUDIT,
        desc="Audit cron jobs and at jobs for suspicious entries",
        version="3.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            log_action(self.info.name, "dry run: would scan cron dirs", quiet=self.quiet, no_color=self.no_color)
            return True, "dry run"

        cron_locations = [
            "/etc/crontab", "/etc/cron.d",
            "/etc/cron.hourly", "/etc/cron.daily",
            "/etc/cron.weekly", "/etc/cron.monthly",
            "/var/spool/cron",
        ]

        all_entries: List[str] = []
        for loc in cron_locations:
            p = Path(loc)
            if p.is_file():
                try:
                    lines = p.read_text().splitlines()
                    all_entries += [f"{loc}: {l}" for l in lines if l.strip() and not l.startswith("#")]
                except OSError:
                    pass
            elif p.is_dir():
                for f in p.iterdir():
                    if f.is_file():
                        try:
                            lines = f.read_text().splitlines()
                            all_entries += [f"{f}: {l}" for l in lines if l.strip() and not l.startswith("#")]
                        except OSError:
                            pass

        for entry in all_entries:
            # Flag suspicious patterns
            if re.search(r"(wget|curl|nc |ncat|bash\s+-[ic]|python[23]?\s+-c|eval|base64)", entry):
                self.emit("critical", f"suspicious cron entry: {entry}",
                          remediation="Review and remove if unexpected")
            elif re.search(r"/tmp/|/dev/shm", entry):
                self.emit("warning", f"cron entry referencing temp dir: {entry}",
                          remediation="Verify legitimacy")

        self.emit("info", f"{len(all_entries)} total active cron entries")
        save_report("cron_audit", "\n".join(all_entries))
        self.state.save_findings(self.findings)
        return True, "cron audit completed"

    def status(self): return ModStatus.UNKNOWN


class SecureBoot(Module):
    info = ModInfo(
        name="secureboot", kind=ModKind.CRYPTO,
        desc="Check Secure Boot status and key enrollment",
        version="3.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            log_action(self.info.name, "dry run: would check Secure Boot via mokutil/bootctl", quiet=self.quiet, no_color=self.no_color)
            return True, "dry run"

        # mokutil is the standard tool
        mok = run_cmd(["mokutil", "--sb-state"], log_failure=False)
        if mok.ok:
            out = mok.stdout.strip().lower()
            if "secure boot enabled" in out:
                self.emit("info", "Secure Boot is ENABLED ✓")
            else:
                self.emit("warning", "Secure Boot is DISABLED",
                          mok.stdout,
                          "Enable Secure Boot in UEFI firmware and enroll keys with mokutil")
        else:
            # Try reading EFI variable directly
            sb_var = Path("/sys/firmware/efi/vars/SecureBoot-8be4df61-93ca-11d2-aa0d-00e098032b8c/data")
            if sb_var.exists():
                try:
                    data = sb_var.read_bytes()
                    enabled = data[0] == 1 if data else False
                    if enabled:
                        self.emit("info", "Secure Boot is ENABLED (via EFI var) ✓")
                    else:
                        self.emit("warning", "Secure Boot is DISABLED (via EFI var)",
                                  remediation="Enable in UEFI firmware")
                except OSError:
                    self.emit("info", "Secure Boot status unknown (cannot read EFI var)")
            elif not Path("/sys/firmware/efi").exists():
                self.emit("info", "System not booted in UEFI mode – Secure Boot not applicable")
            else:
                self.emit("info", "mokutil not available – install mokutil for Secure Boot checks")

        self.state.save_findings(self.findings)
        return True, "Secure Boot check completed"

    def status(self): return ModStatus.UNKNOWN


class TimeSyncAudit(Module):
    info = ModInfo(
        name="timesync", kind=ModKind.AUDIT,
        desc="Verify time synchronisation is active (required for logs, certs, Kerberos)",
        version="3.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            log_action(self.info.name, "dry run: would check NTP/chrony/systemd-timesyncd", quiet=self.quiet, no_color=self.no_color)
            return True, "dry run"

        synced = False
        for svc in ["systemd-timesyncd", "chronyd", "ntpd", "openntpd"]:
            r = run_cmd(["systemctl", "is-active", svc], log_failure=False)
            if r.ok and r.stdout.strip() == "active":
                self.emit("info", f"Time sync active via {svc} ✓")
                synced = True
                break

        if not synced:
            self.emit("critical", "No time sync service is active",
                      remediation="Enable systemd-timesyncd: systemctl enable --now systemd-timesyncd")

        # Check clock offset (timedatectl)
        tdc = run_cmd(["timedatectl", "status"], log_failure=False)
        if tdc.ok:
            for line in tdc.stdout_lines:
                if "synchronized" in line.lower() or "NTP" in line:
                    self.emit("info", line.strip())

        self.state.save_findings(self.findings)
        return True, "time sync check completed"

    def status(self): return ModStatus.UNKNOWN


