class AppArmor(Module):
    info = ModInfo(
        name="apparmor", kind=ModKind.MAC,
        desc="enforce AppArmor profiles + add kernel boot parameters",
        version="3.0.0", author="archguard",
        deps=["apparmor"], conflicts=["selinux"],
        reversible=True, risk="high",
    )

    def pre_check(self, force=False, install_deps=False):
        ok, msg = super().pre_check(force, install_deps)
        if not ok:
            return ok, msg
        if not Path("/sys/kernel/security/apparmor").exists():
            return False, "kernel lacks CONFIG_SECURITY_APPARMOR"
        r = run_cmd(["systemctl", "cat", "apparmor.service"], log_failure=False)
        if not r.ok:
            return False, "apparmor.service not found"
        return True, "ok"

    def gen_config(self, **_) -> Dict[str, str]:
        configs: Dict[str, str] = {}

        parser_path = "/etc/apparmor/parser.conf"
        try:
            cur = Path(parser_path).read_text() if Path(parser_path).exists() else ""
        except OSError as exc:
            log_action(self.info.name, f"cannot read {parser_path}: {exc}", "warning", self.quiet, self.no_color)
            cur = ""

        needed_lines = ['AA_ENABLED="yes"', 'APPARMOR_PROFILE_MODE="enforce"', 'WRITE_CACHE="yes"']
        new = cur
        for line in needed_lines:
            if line not in new:
                new += line + "\n"
        if new != cur:
            configs[parser_path] = new

        bl_type, _ = detect_bootloader()
        if bl_type == "grub":
            grub_path = "/etc/default/grub"
            try:
                grub_cur = Path(grub_path).read_text() if Path(grub_path).exists() else ""
            except OSError as exc:
                log_action(self.info.name, f"cannot read {grub_path}: {exc}", "warning", self.quiet, self.no_color)
                grub_cur = ""

            if grub_cur and "GRUB_CMDLINE_LINUX_DEFAULT" in grub_cur:
                def _add_aa(m):
                    line = m.group(0)
                    if "apparmor=1" not in line:
                        line = line.rstrip('"') + ' apparmor=1 security=apparmor"'
                    return line
                grub_new = re.sub(r'GRUB_CMDLINE_LINUX_DEFAULT="[^"]*"', _add_aa, grub_cur)
                if grub_new != grub_cur:
                    configs[grub_path] = grub_new
        elif bl_type == "systemd-boot":
            log_action(self.info.name, "systemd-boot: add 'apparmor=1 security=apparmor' to kernel cmdline manually", "warning", self.quiet, self.no_color)

        return configs

    def apply(self, dry=False, force=False, verify=False, **kw):
        ok, msg = super().apply(dry, force, verify, **kw)
        if ok and not dry:
            run_cmd(["systemctl", "enable", "apparmor"], module=self.info.name, quiet=self.quiet, no_color=self.no_color)
            run_cmd(["systemctl", "start",  "apparmor"], module=self.info.name, quiet=self.quiet, no_color=self.no_color)

            aa_enforce = shutil.which("aa-enforce")
            if aa_enforce:
                for prof in ["usr.bin.firefox", "usr.bin.chromium", "usr.bin.ssh", "usr.sbin.cupsd", "usr.bin.evince"]:
                    p = Path("/etc/apparmor.d") / prof
                    if p.exists():
                        run_cmd([aa_enforce, str(p)], log_failure=False)
            else:
                log_action(self.info.name, "aa-enforce not found – install apparmor-utils", "warning", self.quiet, self.no_color)

            if any(c["path"] == "/etc/default/grub" for c in self.state.get(self.info.name)):
                r = run_cmd(["grub-mkconfig", "-o", "/boot/grub/grub.cfg"],
                            module=self.info.name, quiet=self.quiet, no_color=self.no_color, timeout=60)
                if not r.ok:
                    log_action(self.info.name, "grub-mkconfig failed – check output above", "error", self.quiet, self.no_color)
                    return False, "grub-mkconfig failed"
                log_action(self.info.name, "reboot required for AppArmor kernel params", "warning", self.quiet, self.no_color)
        return ok, msg

    def status(self):
        r = run_cmd(["aa-status", "--enabled"], log_failure=False)
        return ModStatus.APPLIED if r.ok else ModStatus.UNKNOWN

    def verify(self):
        r = run_cmd(["aa-status", "--enabled"], log_failure=False)
        return (True, "ok") if r.ok else (False, "AppArmor not enabled in kernel")


