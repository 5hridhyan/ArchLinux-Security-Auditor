class ServiceMin(Module):
    info = ModInfo(
        name="services", kind=ModKind.SERVICE,
        desc="detect and optionally disable unnecessary/risky services",
        version="3.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=True, risk="high",
    )

    SUSPICIOUS = {
        "avahi-daemon.service", "cups.service", "bluetooth.service",
        "rpcbind.service", "nfs-server.service", "smb.service",
        "telnet.socket", "vsftpd.service", "inetd.service",
        "xinetd.service", "rsh.socket", "rlogin.socket",
    }

    def _running_and_enabled(self):
        r_run = run_cmd(["systemctl", "list-units", "--type=service", "--state=running", "--no-legend"], log_failure=False)
        r_ena = run_cmd(["systemctl", "list-unit-files", "--type=service", "--state=enabled", "--no-legend"], log_failure=False)
        running = {l.split()[0] for l in r_run.stdout_lines if l}
        enabled = {l.split()[0] for l in r_ena.stdout_lines if l}
        return running, enabled

    def apply(self, dry=False, force=False, verify=False, **kw):
        running, enabled = self._running_and_enabled()
        suspicious = (running | enabled) & self.SUSPICIOUS

        if self.verbose:
            print(f"\n  running: {len(running)}  enabled: {len(enabled)}  suspicious: {len(suspicious)}")

        if not suspicious:
            log_action(self.info.name, "no suspicious services found", quiet=self.quiet, no_color=self.no_color)
            return True, "nothing to do"

        if not self.quiet:
            print("\n  Potentially unnecessary services:")
            for s in sorted(suspicious):
                flags = ", ".join(f for f, coll in [("running", running), ("enabled", enabled)] if s in coll)
                print(f"    - {s} ({flags})")

        if dry:
            return True, "dry run complete"

        if not force:
            try:
                resp = input("\ndisable these services? [y/N] ")
            except EOFError:
                resp = "n"
            if resp.strip().lower() != "y":
                return True, "no changes made"

        for svc in suspicious:
            run_cmd(["systemctl", "stop",    svc], module=self.info.name, quiet=self.quiet, no_color=self.no_color)
            run_cmd(["systemctl", "disable", svc], module=self.info.name, quiet=self.quiet, no_color=self.no_color)
            marker = "DISABLED_RUNNING" if svc in running else "DISABLED_ENABLED"
            self.state.add(self.info.name, f"service:{svc}", marker)
            log_action(self.info.name, f"disabled {svc}", quiet=self.quiet, no_color=self.no_color)

        if verify:
            running2, enabled2 = self._running_and_enabled()
            still = suspicious & (running2 | enabled2)
            if still:
                log_action(self.info.name, f"still active after disable: {', '.join(still)}", "warning", self.quiet, self.no_color)

        return True, f"disabled {len(suspicious)} service(s)"

    def revert(self):
        changes = self.state.get(self.info.name)
        if not changes:
            return False, "no recorded changes"
        reverted = 0
        for rec in changes:
            if not rec["path"].startswith("service:"):
                continue
            svc, marker = rec["path"][8:], rec["backup"]
            run_cmd(["systemctl", "enable", svc], module=self.info.name, quiet=self.quiet, no_color=self.no_color)
            if marker == "DISABLED_RUNNING":
                run_cmd(["systemctl", "start", svc], module=self.info.name, quiet=self.quiet, no_color=self.no_color)
            log_action(self.info.name, f"re-enabled {svc}", quiet=self.quiet, no_color=self.no_color)
            reverted += 1
            self.state.remove(self.info.name, rec["path"], marker)
        return (True, f"re-enabled {reverted} service(s)") if reverted else (False, "nothing to re-enable")

    def status(self):
        running, enabled = self._running_and_enabled()
        return ModStatus.APPLIED if not ((running | enabled) & self.SUSPICIOUS) else ModStatus.PARTIAL


