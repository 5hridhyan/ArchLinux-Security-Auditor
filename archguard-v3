class ArchSecurity(Module):
    info = ModInfo(
        name="archsec", kind=ModKind.AUDIT,
        desc="Check installed packages against Arch Linux CVE tracker",
        version="3.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    CVE_URL = "https://security.archlinux.org/all.json"
    CACHE_KEY = "archsec_cve_json"
    CACHE_TTL = 3600  # 1 hour

    def _fetch_cve_data(self) -> Optional[list]:
        cached = cache_get(self.CACHE_KEY, self.CACHE_TTL)
        if cached:
            try:
                return json.loads(cached)
            except json.JSONDecodeError:
                pass

        try:
            with urllib.request.urlopen(self.CVE_URL, timeout=30) as resp:
                raw = resp.read().decode()
            cache_put(self.CACHE_KEY, raw)
            return json.loads(raw)
        except urllib.error.URLError as exc:
            log_action(self.info.name, f"network error fetching CVE data: {exc}", "error", self.quiet, self.no_color)
            return None
        except json.JSONDecodeError as exc:
            log_action(self.info.name, f"invalid JSON from CVE tracker: {exc}", "error", self.quiet, self.no_color)
            return None

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            log_action(self.info.name, "dry run: would fetch CVE data from security.archlinux.org", quiet=self.quiet, no_color=self.no_color)
            return True, "dry run"

        data = self._fetch_cve_data()
        if data is None:
            return False, "could not fetch CVE data"

        # Build installed package dict: name -> version
        r = run_cmd(["pacman", "-Q"], log_failure=False)
        installed: Dict[str, str] = {}
        for line in r.stdout_lines:
            parts = line.split(" ", 1)
            if len(parts) == 2:
                installed[parts[0]] = parts[1].strip()

        vulnerable = []
        for adv in data:
            pkg = adv.get("package", "")
            if pkg not in installed:
                continue
            fixed = adv.get("fixed")
            if not fixed:
                # no fixed version yet → still vulnerable
                vulnerable.append(adv)
                continue
            installed_ver = installed[pkg]
            # vercmp returns < 0 if installed_ver < fixed → still vulnerable
            if vercmp(installed_ver, fixed) < 0:
                vulnerable.append(adv)

        report_lines = []
        for adv in vulnerable:
            severity = adv.get("severity", "unknown")
            pkg_name = adv.get("package", "?")
            adv_id   = adv.get("advisory", "?")
            adv_type = adv.get("type", "?")
            fixed    = adv.get("fixed", "not yet fixed")
            line = f"{pkg_name}: {adv_type} [{severity}] {adv_id} (fix: {fixed})"
            report_lines.append(line)
            sev = "critical" if severity in ("Critical", "High") else "warning"
            self.emit(sev, line, remediation=f"pacman -Syu {pkg_name}")

        save_report("archsec", "\n".join(report_lines))
        self.state.save_findings(self.findings)

        if vulnerable:
            return False, f"{len(vulnerable)} vulnerable package(s)"
        return True, "no known vulnerable packages"

    def status(self): return ModStatus.UNKNOWN


