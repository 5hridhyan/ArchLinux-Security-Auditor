        self.available_targets: List[str] = []

    def pre_check(self, force=False, install_deps=False):
        ok, msg = super().pre_check(force, install_deps)
        if not ok: return ok, msg
        self.available_targets = [
            s for s in self.TARGETS
            if run_cmd(["systemctl", "cat", s], log_failure=False).ok
        ]
        if not self.available_targets:
            return False, "no target services found on this system"
        return True, "ok"

    def gen_config(self, **_):
        if not self._pre_checked:
            return {}
        overrides: Dict[str, str] = {}
        content = """\
[Service]
# added by archguard
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
NoNewPrivileges=yes
RestrictSUIDSGID=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
"""
        for svc in self.available_targets:
            f = Path(f"/etc/systemd/system/{svc}.d/archguard-sandbox.conf")
            if not f.exists():
                overrides[str(f)] = content
        return overrides

    def apply(self, dry=False, force=False, verify=False, **kw):
        ok, msg = super().apply(dry, force, verify, **kw)
        if ok and not dry:
            run_cmd(["systemctl", "daemon-reload"], module=self.info.name, quiet=self.quiet, no_color=self.no_color)
            if force:
                for svc in self.available_targets:
                    run_cmd(["systemctl", "try-restart", svc], module=self.info.name, quiet=self.quiet, no_color=self.no_color)
        return ok, msg

    def status(self):
        existing = [s for s in self.TARGETS if run_cmd(["systemctl", "cat", s], log_failure=False).ok]
        if not existing: return ModStatus.UNKNOWN
        found = sum(1 for s in existing if Path(f"/etc/systemd/system/{s}.d/archguard-sandbox.conf").exists())
        if found == len(existing): return ModStatus.APPLIED
        if found > 0:              return ModStatus.PARTIAL
        return ModStatus.UNKNOWN



