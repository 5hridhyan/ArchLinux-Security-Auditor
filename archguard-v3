#  persistent state 

class State:
    STATE_DIR     = Path("/var/lib/archguard")
    STATE_FILE    = STATE_DIR / "state.json"
    FINDINGS_FILE = STATE_DIR / "findings.json"
    SCHEMA_VERSION = 3

    def __init__(self):
        self.STATE_DIR.mkdir(parents=True, exist_ok=True)
        self.data: Dict[str, List[Dict]] = self._load()
        self.findings: List[Dict] = self._load_findings()

    def _load(self) -> Dict[str, List[Dict]]:
        if not self.STATE_FILE.exists():
            return {}
        try:
            raw = json.loads(self.STATE_FILE.read_text())
            if isinstance(raw, dict) and "_schema_version" in raw:
                v = raw["_schema_version"]
                if v != self.SCHEMA_VERSION:
                    print(
                        f"warning: state schema v{v}, expected v{self.SCHEMA_VERSION} – loading anyway",
                        file=sys.stderr,
                    )
                return raw.get("modules", {})
            return raw  # legacy format
        except (json.JSONDecodeError, OSError) as exc:
            _log.warning("could not load state file (%s): %s", self.STATE_FILE, exc)
            return {}

    def _save(self):
        tmp = self.STATE_FILE.with_suffix(".tmp")
        try:
            tmp.write_text(json.dumps({"_schema_version": self.SCHEMA_VERSION, "modules": self.data}, indent=2))
            tmp.rename(self.STATE_FILE)
        except OSError as exc:
            _log.error("could not save state: %s", exc)

    def add(self, module: str, path: str, backup: str, checksum: str = ""):
        rec: Dict[str, Any] = {"module": module, "path": path, "backup": backup, "when": datetime.now().isoformat()}
        if checksum:
            rec["checksum"] = checksum
        self.data.setdefault(module, []).append(rec)
        self._save()

    def get(self, module: str = None, since: datetime = None, limit: int = None) -> List[Dict]:
        recs = list(self.data.get(module, [])) if module else [r for ml in self.data.values() for r in ml]
        recs.sort(key=lambda r: r["when"], reverse=True)
        if since:
            recs = [r for r in recs if datetime.fromisoformat(r["when"]) >= since]
        if limit:
            recs = recs[:limit]
        return recs

    def remove(self, module: str, path: str, backup: str):
        if module in self.data:
            self.data[module] = [r for r in self.data[module] if not (r["path"] == path and r["backup"] == backup)]
            if not self.data[module]:
                del self.data[module]
            self._save()

    # ── findings persistence ──

    def _load_findings(self) -> List[Dict]:
        if not self.FINDINGS_FILE.exists():
            return []
        try:
            return json.loads(self.FINDINGS_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            return []

    def save_findings(self, findings: List[Finding]):
        merged = self.findings + [f.to_dict() for f in findings]
        # keep only findings from last 30 days
        cutoff = (datetime.now() - timedelta(days=30)).isoformat()
        merged = [f for f in merged if f.get("when", "9999") >= cutoff]
        for f in merged:
            f.setdefault("when", datetime.now().isoformat())
        try:
            tmp = self.FINDINGS_FILE.with_suffix(".tmp")
            tmp.write_text(json.dumps(merged, indent=2))
            tmp.rename(self.FINDINGS_FILE)
            self.findings = merged
        except OSError as exc:
            _log.warning("could not save findings: %s", exc)


#  backup manager 

class BackupKeeper:
    BACKUP_DIR = Path("/var/backups/archguard")

    def __init__(self, state: State):
        self.dir = self.BACKUP_DIR
        self.dir.mkdir(parents=True, exist_ok=True)
        self.state = state

    @staticmethod
    def _file_hash(path: Path) -> str:
        sha = hashlib.sha256()
        with open(path, "rb") as f:
            for block in iter(lambda: f.read(65536), b""):
                sha.update(block)
        return sha.hexdigest()

    @staticmethod
    def _copy_with_permissions(src: Path, dst: Path):
        shutil.copy2(src, dst)
        st = src.stat()
        os.chown(dst, st.st_uid, st.st_gid)
        os.chmod(dst, st.st_mode)

    def create(self, path: str, module: str) -> Optional[Path]:
        src = Path(path)
        if not src.exists():
            return None
        stamp = datetime.now().strftime("%Y%m%d_%H%M%S_%f")
        dest = self.dir / f"{src.name}.{module}.{stamp}.backup"
        try:
            self._copy_with_permissions(src, dest)
        except (OSError, shutil.Error) as exc:
            _log.error("backup create failed for %s: %s", path, exc)
            return None
        h = self._file_hash(dest)
        self.state.add(module, path, str(dest), h)
        return dest

    def restore(self, path: str, backup_path: Path, expected_hash: str = "") -> bool:
        if expected_hash:
            try:
                actual = self._file_hash(backup_path)
            except OSError as exc:
                _log.error("cannot hash backup %s: %s", backup_path, exc)
                return False
            if actual != expected_hash:
                log_action("backup", f"hash mismatch for {backup_path} (expected {expected_hash[:12]}…, got {actual[:12]}…)", "error")
                return False
        try:
            dest = Path(path)
            dest.parent.mkdir(parents=True, exist_ok=True)
            self._copy_with_permissions(backup_path, dest)
            return True
        except (OSError, shutil.Error) as exc:
            _log.error("restore failed for %s: %s", path, exc)
            return False


#  atomic write 

def atomic_write(path: Path, content: str, reference: Optional[Path], no_color: bool) -> bool:
    tmp_path: Optional[Path] = None
    try:
        fd, raw_tmp = tempfile.mkstemp(dir=path.parent, prefix=path.name + ".tmp")
        tmp_path = Path(raw_tmp)
        with os.fdopen(fd, "w") as f:
            f.write(content)

        # inherit permissions from reference or existing file; else sane default
        ref = reference if (reference and reference.exists()) else (path if path.exists() else None)
        if ref:
            st = ref.stat()
            os.chown(tmp_path, st.st_uid, st.st_gid)
            os.chmod(tmp_path, st.st_mode)
        else:
            os.chown(tmp_path, 0, 0)
            os.chmod(tmp_path, 0o644)

        tmp_path.rename(path)
        return True
    except (OSError, PermissionError) as exc:
        log_action("atomic_write", f"failed writing {path}: {exc}", "error", no_color=no_color)
        if tmp_path and tmp_path.exists():
            try:
                tmp_path.unlink()
            except OSError:
                pass
        return False


#  diff viewer 

def show_diff(old: str, new: str, path: str, verbose: bool, no_color: bool):
    if not verbose:
        return
    diff = list(difflib.unified_diff(
        old.splitlines(keepends=True),
        new.splitlines(keepends=True),
        fromfile=f"{path} (current)",
        tofile=f"{path} (new)",
    ))
    if not diff:
        return
    print("\n" + "=" * 60)
    print(f"Changes for: {path}")
    print("=" * 60)
    for line in diff:
        if no_color:
            print(line, end="")
        elif line.startswith("+"):
            print(f"\033[92m{line}\033[0m", end="")
        elif line.startswith("-"):
            print(f"\033[91m{line}\033[0m", end="")
        elif line.startswith("@"):
            print(f"\033[94m{line}\033[0m", end="")
        else:
            print(line, end="")
    print("\n" + "=" * 60)


#  bootloader detection 

def detect_bootloader() -> Tuple[Optional[str], Optional[Path]]:
    if Path("/boot/grub/grub.cfg").exists():
        return "grub", Path("/boot/grub/grub.cfg")
    if Path("/boot/loader/entries").is_dir():
        return "systemd-boot", None
    if Path("/efi/EFI").is_dir() and list(Path("/efi/EFI").glob("*.efi")):
        return "efistub", None
    return None, None


