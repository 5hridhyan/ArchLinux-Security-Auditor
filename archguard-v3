                    "ssh_audit", "sudo_audit", "world_writable",
                    "suid_audit", "cron_audit", "secureboot", "timesync"],
}

AUDIT_KINDS = {ModKind.AUDIT, ModKind.MALWARE, ModKind.INTEGRITY,
               ModKind.NETWORK, ModKind.ACCESS, ModKind.CRYPTO}


# THE MAIN ONE

class ArchGuard:
    def __init__(self, quiet=False, verbose=False, no_color=False):
        self.quiet    = quiet
        self.verbose  = verbose
        self.no_color = no_color
        self.state    = State()

        def M(cls): return cls(self.state, quiet, verbose, no_color)

        self.modules: Dict[str, Module] = {
            "firewall":        M(Firewall),
            "apparmor":        M(AppArmor),
            "kernel":          M(Kernel),
            "services":        M(ServiceMin),
            "firejail":        M(Firejail),
            "auditd":          M(AuditD),
            "usb_lockdown":    M(UsbLockdown),
            "systemd_sandbox": M(SystemdSandbox),
            "kernel_modules":  M(KernelModules),
            "rkhunter":        M(RootkitHunter),
            "lynis":           M(Lynis),
            "aide":            M(AIDE),
            "clamav":          M(ClamAV),
            "archsec":         M(ArchSecurity),
            "network_audit":   M(NetworkAudit),
            "pkg_verify":      M(PackageVerification),
            "log_audit":       M(LogAudit),
            "ssh_audit":       M(SSHAudit),
            "sudo_audit":      M(SudoAudit),
            "world_writable":  M(WorldWritableAudit),
            "suid_audit":      M(SuidAudit),
            "cron_audit":      M(CronAudit),
            "secureboot":      M(SecureBoot),
            "timesync":        M(TimeSyncAudit),
        }

        for preset, mods in PRESETS.items():
            for m in mods:
                if m not in self.modules:
                    raise RuntimeError(f"preset '{preset}' references unknown module '{m}'")

    def _c(self, text: str, code: str) -> str:
        return text if self.no_color else f"\033[{code}m{text}\033[0m"

    def _print(self, *args, **kw):
        if not self.quiet:
            print(*args, **kw)

    def list(self):
        self._print()
        self._print(self._c("archguard – available modules", "1"))
        self._print("=" * 64)
        shown_kinds: set = set()
        for name, mod in self.modules.items():
            kind = mod.info.kind
            if kind not in shown_kinds:
                self._print(f"\n  {self._c(kind.value.upper(), '94')}")
                shown_kinds.add(kind)
            stat = mod.status()
            sym = {"applied":"✓","partial":"◔","unknown":"○","conflict":"✗","error":"⚠"}.get(stat.value,"○")
            rev = "↩" if mod.info.reversible else " "
            self._print(f"    {sym} {rev} {self._c(name,'1'):<28} {mod.info.desc}")

    def status(self):
        self._print(f"\n{self._c('Hardening status','1')}")
        self._print("=" * 50)
        for name, mod in self.modules.items():
            if mod.info.kind in AUDIT_KINDS: continue
            stat = mod.status()
            disp = {
                ModStatus.APPLIED:  self._c("APPLIED",     "92"),
                ModStatus.PARTIAL:  self._c("PARTIAL",     "93"),
                ModStatus.UNKNOWN:  self._c("NOT APPLIED", "90"),
                ModStatus.CONFLICT: self._c("CONFLICT",    "91"),
                ModStatus.ERROR:    self._c("ERROR",       "91"),
            }.get(stat, self._c("UNKNOWN","90"))
            print(f"  {name:<22} {disp}")

    def apply_one(self, name: str, dry=False, force=False, verify=False, **kw) -> bool:
        if name not in self.modules:
            print(f"unknown module: {name!r}")
            return False
        mod = self.modules[name]
        self._print(f"\n{self._c('▶','94')} {self._c(name,'1')} – {mod.info.desc}")
        self._print("-" * 50)
        if dry: self._print(self._c("  dry run – no changes will be written","93"))
        ok, msg = mod.apply(dry, force, verify, **kw)
        self._print(f"\n{self._c('✓','92') if ok else self._c('✗','91')} {msg}")
        return ok

    def apply_preset(self, preset: str, dry=False, force=False, verify=False, install_deps=False):
        if preset not in PRESETS:
            print(f"unknown preset: {preset!r}"); return
        self._print(f"\n{self._c('Preset:','94')} {self._c(preset,'1')}")
        for name in PRESETS[preset]:
            self.apply_one(name, dry, force, verify, install_deps=install_deps)
            self._print()

    def revert(self, name: str):
        if name not in self.modules:
            print(f"unknown module: {name!r}"); return
        mod = self.modules[name]
        self._print(f"\n{self._c('↩ reverting','94')} {self._c(name,'1')}")
        self._print("-" * 50)
        ok, msg = mod.revert()
        self._print(f"\n{self._c('✓','92') if ok else self._c('✗','91')} {msg}")

    def backups(self, module=None, days=None, limit=None):
        since = datetime.now() - timedelta(days=days) if days else None
        recs  = self.state.get(module, since=since, limit=limit)
        if not recs:
            print("no backups found"); return
        self._print(f"\n{self._c('Backup history','1')}")
        self._print("=" * 60)
        for r in recs:
            print(f"  {r['when']}  {r['module']:<18}  {r['path']}  →  {r['backup']}")

    def report(self):
        findings = self.state.findings
        if not findings:
            print("No findings recorded. Run audit modules first."); return
        by_sev: Dict[str, List[Dict]] = {}
        for f in findings:
            by_sev.setdefault(f.get("severity","info"), []).append(f)
        self._print(f"\n{self._c('archguard – Security Report','1')}")
        self._print(f"Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
        self._print("=" * 64)
        for sev, color in [("critical","91"),("warning","93"),("info","92")]:
            items = by_sev.get(sev, [])
            if not items: continue
            self._print(f"\n{self._c(sev.upper(),color)} ({len(items)})")
            for f in items:
                self._print(f"  [{f.get('module','?')}] {f.get('title','')}")
                if self.verbose and f.get("remediation"):
                    self._print(f"      → {f['remediation']}")
        crits = len(by_sev.get("critical",[]))
        warns = len(by_sev.get("warning",[]))
        self._print(f"\n  Total: {len(findings)}  Critical: {self._c(str(crits),'91')}  Warnings: {self._c(str(warns),'93')}")
        self._print(f"  Reports in: {LOG_DIR}/")
        self._print("=" * 64)


# ENTRY POINT

def main():
    parser = argparse.ArgumentParser(
        prog="archguard",
        description="archguard – aggressive security auditing & hardening for Arch Linux",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  archguard list
  archguard status
  archguard apply firewall --profile workstation --verify
  archguard apply --preset hardened --force --verify
  archguard audit ssh_audit
  archguard audit --preset quick_audit
  archguard audit --preset full_audit --install-deps
  archguard report --verbose
  archguard revert firewall
  archguard backups --days 7
""",
    )
    parser.add_argument("--quiet",    action="store_true")
    parser.add_argument("--verbose",  action="store_true")
    parser.add_argument("--no-color", action="store_true")

    sub = parser.add_subparsers(dest="cmd", required=True)

    sub.add_parser("list")
    sub.add_parser("status")
    sub.add_parser("report")

    bp = sub.add_parser("backups")
    bp.add_argument("--module"); bp.add_argument("--days", type=int); bp.add_argument("--limit", type=int)

    ap = sub.add_parser("apply")
    ap.add_argument("name", nargs="?")
    ap.add_argument("--preset",       choices=PRESETS.keys())
    ap.add_argument("--dry-run",      action="store_true")
    ap.add_argument("--force", "-f",  action="store_true")
    ap.add_argument("--verify",       action="store_true")
    ap.add_argument("--install-deps", action="store_true")
    ap.add_argument("--profile",      choices=["workstation","server","paranoid","strict"])
    ap.add_argument("--paranoid",     action="store_true")

    aup = sub.add_parser("audit")
    aup.add_argument("name",          nargs="?")
    aup.add_argument("--preset",      choices=PRESETS.keys())
    aup.add_argument("--dry-run",     action="store_true")
    aup.add_argument("--force","-f",  action="store_true")
    aup.add_argument("--install-deps",action="store_true")

    rv = sub.add_parser("revert")
    rv.add_argument("module")

    args = parser.parse_args()

    if not sys.stdout.isatty():
        args.no_color = True

    if args.cmd in ("apply", "revert") and os.geteuid() != 0:
        print("error: requires root – run with sudo", file=sys.stderr)
        sys.exit(1)

    app = ArchGuard(quiet=args.quiet, verbose=args.verbose, no_color=args.no_color)

    if args.cmd == "list":
        app.list()

    elif args.cmd == "status":
        app.status()

    elif args.cmd == "report":
        app.report()

    elif args.cmd == "backups":
        app.backups(args.module, args.days, args.limit)

    elif args.cmd == "apply":
        if args.preset:
            app.apply_preset(args.preset, args.dry_run, args.force, args.verify,
                             install_deps=args.install_deps)
        elif args.name:
            kw: Dict[str, Any] = {"install_deps": args.install_deps}
            if args.name == "firewall" and args.profile: kw["profile"] = args.profile
            if args.name == "kernel"   and args.paranoid: kw["paranoid"] = True
            app.apply_one(args.name, args.dry_run, args.force, args.verify, **kw)
        else:
            ap.print_help()

    elif args.cmd == "audit":
        if args.preset:
            for name in PRESETS.get(args.preset, []):
                mod = app.modules.get(name)
                if mod and mod.info.kind in AUDIT_KINDS:
                    app.apply_one(name, args.dry_run, args.force, False,
                                  install_deps=args.install_deps)
        elif args.name:
            if args.name not in app.modules:
                print(f"unknown module: {args.name!r}"); sys.exit(1)
            mod = app.modules[args.name]
            if mod.info.kind not in AUDIT_KINDS:
                print(f"'{args.name}' is a hardening module – use 'apply'"); sys.exit(1)
            ok, msg = mod.apply(dry=args.dry_run, force=args.force,
                                install_deps=args.install_deps)
            if not args.quiet:
                print(f"\n{'✓' if ok else '✗'} {msg}")
            if not ok:
                sys.exit(1)
        else:
            aup.print_help()

    elif args.cmd == "revert":
        app.revert(args.module)


if __name__ == "__main__":
    main()
