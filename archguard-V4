class CronAudit(Module):
    info = ModInfo(
        name="cron_audit", kind=ModKind.AUDIT,
        desc="audit cron/at jobs for suspicious commands and world-writable scripts",
        version="4.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    CRON_PATHS = [
        "/etc/crontab", "/etc/cron.d", "/etc/cron.hourly", "/etc/cron.daily",
        "/etc/cron.weekly", "/etc/cron.monthly", "/var/spool/cron",
    ]

    # Patterns that strongly suggest malicious cron entries
    _DANGER = re.compile(
        r"wget\s|curl\s|nc\s|ncat\s|bash\s+-[ic]|sh\s+-[ic]"
        r"|python[23]?\s+-c|perl\s+-e|ruby\s+-e"
        r"|eval\s|base64\s+-d|/dev/tcp|/dev/udp"
        r"|mkfifo|mknod.*\|",
        re.IGNORECASE,
    )
    _SUSPICIOUS = re.compile(r"/tmp/|/dev/shm|/var/tmp", re.IGNORECASE)

    def _collect(self) -> List[str]:
        entries: List[str] = []
        for loc in self.CRON_PATHS:
            p = Path(loc)
            if p.is_file():
                try:
                    for line in p.read_text().splitlines():
                        if line.strip() and not line.startswith("#"):
                            entries.append(f"{p}: {line}")
                except OSError:
                    pass
            elif p.is_dir():
                for f in sorted(p.iterdir()):
                    if f.is_file():
                        try:
                            for line in f.read_text().splitlines():
                                if line.strip() and not line.startswith("#"):
                                    entries.append(f"{f}: {line}")
                        except OSError:
                            pass
        return entries

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            return True, "dry run: would scan cron directories"

        entries = self._collect()
        for entry in entries:
            if self._DANGER.search(entry):
                self.emit("critical", f"dangerous cron pattern: {entry}",
                          remediation="Remove immediately if unexpected")
            elif self._SUSPICIOUS.search(entry):
                self.emit("warning", f"cron uses temp dir: {entry}",
                          remediation="Verify legitimacy; tmp-dir scripts are a persistence TTP")

            # Check if the script itself is world-writable
            m = re.search(r"(/[^\s;|&]+\.(sh|py|pl|rb))", entry)
            if m:
                sp = Path(m.group(1))
                if sp.exists() and (sp.stat().st_mode & 0o002):
                    self.emit("critical",
                              f"world-writable cron script: {sp}",
                              remediation=f"chmod 700 {sp}")

        self.emit("info", f"{len(entries)} active cron entries scanned")
        save_report("cron_audit", "\n".join(entries))
        self.state.save_findings(self.findings)
        return True, "cron audit completed"

    def status(self): return ModStatus.UNKNOWN


