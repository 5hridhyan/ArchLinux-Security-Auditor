class SudoAudit(Module):
    info = ModInfo(
        name="sudo_audit", kind=ModKind.ACCESS,
        desc="audit sudoers for NOPASSWD, ALL grants, shell escapes, risky env vars",
        version="4.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            return True, "dry run: would read /etc/sudoers"

        paths: List[Path] = [Path("/etc/sudoers")]
        sd = Path("/etc/sudoers.d")
        if sd.is_dir():
            paths += [f for f in sd.iterdir() if f.is_file()]

        all_lines: List[str] = []
        for sf in paths:
            try:
                all_lines += [
                    f"{sf}:{n+1}: {l}"
                    for n, l in enumerate(sf.read_text().splitlines())
                ]
            except OSError as exc:
                log_action(self.info.name, f"cannot read {sf}: {exc}",
                           "warning", self.quiet, self.no_color)

        has_nopasswd_all = False
        for entry in all_lines:
            line = entry.split(": ", 1)[-1].strip()
            if not line or line.startswith("#"):
                continue

            if "NOPASSWD" in line:
                if re.search(r"ALL\s*=\s*\(ALL\b", line):
                    has_nopasswd_all = True
                    self.emit("critical",
                              f"Unrestricted NOPASSWD ALL grant: {entry}",
                              remediation="This is equivalent to passwordless root – remove")
                else:
                    self.emit("warning", f"NOPASSWD rule: {entry}",
                              remediation="Restrict to specific commands if possible")

            if re.search(r"/(bin|usr/bin)/(sh|bash|zsh|fish|dash|csh|ksh)\b", line):
                self.emit("warning", f"Shell in sudoers (escape risk): {entry}",
                          remediation="Avoid granting sudo to interactive shells")

            # env_keep / env_reset override
            if re.search(r"env_reset\s*!", line, re.IGNORECASE):
                self.emit("warning", f"env_reset disabled: {entry}",
                          remediation="Never disable env_reset – allows env injection attacks")

            if re.search(r"SETENV", line):
                self.emit("warning", f"SETENV flag in sudoers: {entry}",
                          remediation="SETENV allows env manipulation – review carefully")

        if not has_nopasswd_all:
            self.emit("info", "no unrestricted NOPASSWD ALL grants found")

        # Check sudoers syntax
        r = run_cmd(["visudo", "-c"], log_failure=False)
        if not r.ok:
            self.emit("critical", "sudoers syntax check failed",
                      r.stdout + r.stderr,
                      remediation="Fix sudoers: visudo")
        else:
            self.emit("info", "sudoers syntax OK")

        save_report("sudo_audit", "\n".join(f.title for f in self.findings))
        self.state.save_findings(self.findings)
        return True, "sudoers audit completed"

    def status(self): return ModStatus.UNKNOWN


