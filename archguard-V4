#  MAIN ORCHESTRATOR

class ArchGuard:
    def __init__(self, quiet=False, verbose=False, no_color=False) -> None:
        self.quiet    = quiet
        self.verbose  = verbose
        self.no_color = no_color
        self.state    = State()

        def M(cls: type) -> Module:
            return cls(self.state, quiet, verbose, no_color)

        self.modules: Dict[str, Module] = {
            # hardening
            "firewall":        M(Firewall),
            "apparmor":        M(AppArmor),
            "kernel":          M(Kernel),
            "services":        M(ServiceMin),
            "firejail":        M(Firejail),
            "auditd":          M(AuditD),
            "usb_lockdown":    M(UsbLockdown),
            "systemd_sandbox": M(SystemdSandbox),
            "kernel_modules":  M(KernelModules),
            #  audit
            "rkhunter":        M(RootkitHunter),
            "lynis":           M(Lynis),
            "aide":            M(AIDE),
            "clamav":          M(ClamAV),
            "archsec":         M(ArchSecurity),
            "network_audit":   M(NetworkAudit),
            "pkg_verify":      M(PackageVerification),
            "log_audit":       M(LogAudit),
            "ssh_audit":       M(SSHAudit),
            "sudo_audit":      M(SudoAudit),
            "world_writable":  M(WorldWritableAudit),
            "suid_audit":      M(SuidAudit),
            "cron_audit":      M(CronAudit),
            "secureboot":      M(SecureBoot),
            "timesync":        M(TimeSyncAudit),
            "mem_security":    M(MemSecurity),
            "passwd_policy":   M(PasswordPolicy),
        }

        # Validate presets at startup
        for preset, mods in PRESETS.items():
            for m in mods:
                if m not in self.modules:
                    raise RuntimeError(f"preset {preset!r} references unknown module {m!r}")

    # pretty-print helpers

    def _p(self, text: str, style: str = "") -> str:
        return _c(text, style, self.no_color)

    def _print(self, *args, **kw) -> None:
        if not self.quiet:
            print(*args, **kw)

    #  list

    def list(self) -> None:
        self._print()
        self._print(self._p("archguard – module listing", "bold"))
        self._print("═" * 68)

        by_kind: Dict[ModKind, List[Tuple[str, Module]]] = {}
        for name, mod in self.modules.items():
            by_kind.setdefault(mod.info.kind, []).append((name, mod))

        for kind, entries in sorted(by_kind.items(), key=lambda x: x[0].value):
            self._print(f"\n  {self._p(kind.value.upper(), 'blue')}")
            for name, mod in entries:
                stat = mod.status()
                sym  = {
                    "applied": self._p("✓", "info"),
                    "partial": self._p("◔", "warning"),
                    "unknown": "○",
                    "conflict": self._p("✗", "error"),
                    "error":    self._p("⚠", "error"),
                }.get(stat.value, "○")
                rev  = "↩" if mod.info.reversible else " "
                risk_color = {"low": "info", "medium": "warning", "high": "error",
                              "critical": "error"}.get(mod.info.risk, "")
                risk_str = self._p(f"[{mod.info.risk}]", risk_color)
                self._print(
                    f"    {sym} {rev} {self._p(name,'bold'):<30}"
                    f" {risk_str:<18} {mod.info.desc}"
                )

    #  status

    def status(self) -> None:
        self._print(f"\n{self._p('Hardening status', 'bold')}")
        self._print("═" * 52)
        for name, mod in self.modules.items():
            if mod.info.kind in AUDIT_KINDS:
                continue
            stat = mod.status()
            disp = {
                ModStatus.APPLIED:  self._p("APPLIED",     "info"),
                ModStatus.PARTIAL:  self._p("PARTIAL",     "warning"),
                ModStatus.UNKNOWN:  self._p("NOT APPLIED", "debug"),
                ModStatus.CONFLICT: self._p("CONFLICT",    "error"),
                ModStatus.ERROR:    self._p("ERROR",       "error"),
            }.get(stat, self._p("UNKNOWN", "debug"))
            print(f"  {name:<24} {disp}")

    #  apply_one

    def apply_one(
        self, name: str,
        dry=False, force=False, verify=False, install_deps=False,
        **kw,
    ) -> bool:
        if name not in self.modules:
            print(f"unknown module: {name!r}")
            return False
        mod = self.modules[name]
        self._print(
            f"\n{self._p('▶', 'blue')} {self._p(name, 'bold')} – {mod.info.desc}"
        )
        self._print("─" * 52)
        if dry:
            self._print(self._p("  dry run – no changes will be written", "warning"))

        ok, msg = mod.apply(dry, force, verify, install_deps=install_deps, **kw)
        icon = self._p("✓", "info") if ok else self._p("✗", "error")
        self._print(f"\n  {icon} {msg}")
        return ok

    #  apply_preset

    def apply_preset(
        self, preset: str,
        dry=False, force=False, verify=False, install_deps=False,
    ) -> None:
        if preset not in PRESETS:
            print(f"unknown preset: {preset!r}"); return
        self._print(
            f"\n{self._p('Preset:', 'blue')} {self._p(preset, 'bold')} "
            f"({len(PRESETS[preset])} module(s))"
        )
        results: List[Tuple[str, bool]] = []
        for mname in PRESETS[preset]:
            ok = self.apply_one(mname, dry, force, verify, install_deps)
            results.append((mname, ok))
            self._print()

        # Summary
        passed = [n for n, ok in results if ok]
        failed = [n for n, ok in results if not ok]
        self._print("─" * 52)
        self._print(
            f"  Preset {preset!r}: "
            f"{self._p(str(len(passed))+' ok', 'info')}  "
            f"{self._p(str(len(failed))+' failed', 'error' if failed else 'debug')}"
        )

    #  revert 

    def revert(self, name: str) -> None:
        if name not in self.modules:
            print(f"unknown module: {name!r}"); return
        mod = self.modules[name]
        self._print(f"\n{self._p('↩ reverting', 'blue')} {self._p(name, 'bold')}")
        self._print("─" * 52)
        ok, msg = mod.revert()
        icon = self._p("✓", "info") if ok else self._p("✗", "error")
        self._print(f"\n  {icon} {msg}")

    # backups 

    def backups(
        self,
        module: Optional[str] = None,
        days:   Optional[int] = None,
        limit:  Optional[int] = None,
    ) -> None:
        since = datetime.now() - timedelta(days=days) if days else None
        recs  = self.state.get(module, since=since, limit=limit)
        if not recs:
            print("no backups found"); return
        self._print(f"\n{self._p('Backup history', 'bold')}")
        self._print("═" * 72)
        for r in recs:
            ts   = r["when"][:19]
            mod  = r["module"]
            path = r["path"]
            bak  = r["backup"]
            h    = r.get("checksum", "")[:12]
            print(f"  {ts}  {mod:<20}  {path}  →  {Path(bak).name}{' ['+h+'…]' if h else ''}")

    # ── report 

    def report(self) -> None:
        findings = self.state.findings
        if not findings:
            print("No findings. Run audit modules first."); return

        by_sev: Dict[str, List[Dict]] = {}
        for f in findings:
            by_sev.setdefault(f.get("severity", "info"), []).append(f)

        self._print(f"\n{self._p('archguard – Security Report', 'bold')}")
        self._print(f"Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
        self._print(f"Findings stored: {self.state.FINDINGS_FILE}")
        self._print("═" * 68)

        order = [("critical", "error"), ("warning", "warning"), ("info", "info")]
        for sev, col in order:
            items = by_sev.get(sev, [])
            if not items:
                continue
            self._print(f"\n  {self._p(sev.upper(), col)} ({len(items)})")
            for f in items:
                mod    = f.get("module", "?")
                title  = f.get("title", "")
                remed  = f.get("remediation", "")
                cves   = f.get("cve", [])
                self._print(f"    {self._p('['+mod+']','bold')} {title}")
                if cves:
                    self._print(f"         CVE: {', '.join(cves[:5])}")
                if self.verbose and remed:
                    self._print(f"         {self._p('→','cyan')} {remed}")

        crits  = len(by_sev.get("critical", []))
        warns  = len(by_sev.get("warning",  []))
        total  = len(findings)
        self._print(f"\n  Total: {total}  "
                    f"Critical: {self._p(str(crits),'error')}  "
                    f"Warning: {self._p(str(warns),'warning')}")
        self._print(f"  Reports: {LOG_DIR}/")
        self._print("═" * 68)

    # doctor 

    def doctor(self) -> None:
        """Quick read-only diagnostics without running full audit modules."""
        self._print(f"\n{self._p('archguard doctor – system diagnostics', 'bold')}")
        self._print("═" * 60)

        checks: List[Tuple[str, bool, str]] = []

        # Root check
        checks.append(("running as root", os.geteuid() == 0,
                        "some checks require root"))

        # Python version
        checks.append((f"Python {sys.version_info.major}.{sys.version_info.minor}",
                        sys.version_info >= (3, 10), "requires Python 3.10+"))

        # Required tools
        for tool in ("nft", "sysctl", "systemctl", "pacman", "auditctl"):
            checks.append((f"{tool} available", bool(shutil.which(tool)), ""))

        # nftables active
        r = run_cmd(["systemctl", "is-active", "nftables"], log_failure=False)
        checks.append(("nftables active",
                        r.ok and r.stdout.strip() == "active",
                        "archguard apply firewall"))

        # AppArmor
        r2 = run_cmd(["aa-status", "--enabled"], log_failure=False)
        checks.append(("AppArmor enabled", r2.ok, "archguard apply apparmor"))

        # Key sysctl values
        for key, want in [("kernel.kptr_restrict", "2"),
                          ("kernel.dmesg_restrict",  "1"),
                          ("kernel.randomize_va_space", "2")]:
            cur = run_cmd(["sysctl", "-n", key], log_failure=False).stdout.strip()
            checks.append((f"{key}={want}", cur == want,
                           f"archguard apply kernel"))

        # auditd
        r3 = run_cmd(["systemctl", "is-active", "auditd"], log_failure=False)
        checks.append(("auditd active",
                        r3.ok and r3.stdout.strip() == "active",
                        "archguard apply auditd"))

        # Pending updates
        upd = run_cmd(["pacman", "-Qu"], log_failure=False)
        n_upd = len(upd.stdout_lines)
        checks.append((f"pending updates: {n_upd}", n_upd == 0,
                        "pacman -Syu"))

        # UEFI + Secure Boot
        uefi = Path("/sys/firmware/efi").exists()
        checks.append(("UEFI mode", uefi, "system booted in BIOS mode"))
        if uefi:
            sb = run_cmd(["mokutil", "--sb-state"], log_failure=False)
            sb_on = sb.ok and "enabled" in sb.stdout.lower()
            checks.append(("Secure Boot", sb_on, "enable in UEFI firmware"))

        # Time sync
        synced = any(
            run_cmd(["systemctl", "is-active", s], log_failure=False).stdout.strip() == "active"
            for s in ("systemd-timesyncd", "chronyd", "ntpd")
        )
        checks.append(("time sync active", synced, "systemctl enable --now systemd-timesyncd"))

        self._print()
        passed = failed = 0
        for label, ok, hint in checks:
            icon = self._p("✓", "info") if ok else self._p("✗", "error")
            print(f"  {icon} {label}", end="")
            if not ok and hint:
                print(f"  {self._p('→','cyan')} {hint}", end="")
            print()
            if ok: passed += 1
            else:  failed += 1

        self._print()
        self._print(f"  {self._p(str(passed)+' passed', 'info')}  "
                    f"{self._p(str(failed)+' issues', 'error' if failed else 'info')}")
        self._print("═" * 60)


#  ENTRY POINT

def main() -> None:
    parser = argparse.ArgumentParser(
        prog="archguard",
        description="archguard – professional hardening & audit for Arch Linux",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  archguard list
  archguard status
  archguard doctor

  archguard apply firewall --profile workstation --verify
  archguard apply firewall --profile strict --force
  archguard apply kernel --paranoid
  archguard apply --preset hardened --force --verify
  archguard apply --preset desktop --dry-run

  archguard audit ssh_audit
  archguard audit log_audit --verbose
  archguard audit --preset quick_audit
  archguard audit --preset full_audit --install-deps

  archguard report --verbose
  archguard revert firewall
  archguard backups --module firewall --days 7
""",
    )
    parser.add_argument("--quiet",       action="store_true", help="minimal output")
    parser.add_argument("--verbose",     action="store_true", help="show diffs and findings detail")
    parser.add_argument("--no-color",    action="store_true", help="disable ANSI colour")

    sub = parser.add_subparsers(dest="cmd", required=True)

    sub.add_parser("list",   help="list all modules with status")
    sub.add_parser("status", help="show hardening module status")
    sub.add_parser("doctor", help="quick read-only system diagnostics")
    sub.add_parser("report", help="print security findings report")

    bp = sub.add_parser("backups", help="show backup/change history")
    bp.add_argument("--module")
    bp.add_argument("--days",  type=int)
    bp.add_argument("--limit", type=int)

    ap = sub.add_parser("apply", help="apply hardening module or preset")
    ap.add_argument("name",           nargs="?",            help="module name")
    ap.add_argument("--preset",       choices=PRESETS.keys())
    ap.add_argument("--dry-run",      action="store_true",  help="show what would change")
    ap.add_argument("--force",  "-f", action="store_true",  help="skip prompts and conflict checks")
    ap.add_argument("--verify",       action="store_true",  help="verify after applying")
    ap.add_argument("--install-deps", action="store_true",  help="auto-install missing packages")
    ap.add_argument("--profile",
                    choices=["workstation", "server", "paranoid", "strict"],
                    help="firewall profile")
    ap.add_argument("--paranoid",     action="store_true",  help="extra-aggressive sysctl options")

    aup = sub.add_parser("audit", help="run audit module or preset")
    aup.add_argument("name",          nargs="?")
    aup.add_argument("--preset",      choices=PRESETS.keys())
    aup.add_argument("--dry-run",     action="store_true")
    aup.add_argument("--force", "-f", action="store_true")
    aup.add_argument("--install-deps",action="store_true")

    rv = sub.add_parser("revert", help="undo a module's changes")
    rv.add_argument("module")

    args = parser.parse_args()

    # Auto-disable colour when stdout is not a terminal (e.g. redirected to file)
    if not sys.stdout.isatty():
        args.no_color = True

    # Root check for mutating commands
    if args.cmd in ("apply", "revert") and os.geteuid() != 0:
        print("error: 'apply' and 'revert' require root – run with sudo",
              file=sys.stderr)
        sys.exit(1)

    app = ArchGuard(
        quiet=args.quiet,
        verbose=args.verbose,
        no_color=args.no_color,
    )

    match args.cmd:
        case "list":
            app.list()

        case "status":
            app.status()

        case "doctor":
            app.doctor()

        case "report":
            app.report()

        case "backups":
            app.backups(
                getattr(args, "module", None),
                getattr(args, "days",   None),
                getattr(args, "limit",  None),
            )

        case "apply":
            if args.preset:
                app.apply_preset(
                    args.preset, args.dry_run, args.force,
                    args.verify, args.install_deps,
                )
            elif args.name:
                kw: Dict[str, Any] = {"install_deps": args.install_deps}
                if args.name == "firewall" and args.profile:
                    kw["profile"] = args.profile
                if args.name == "kernel" and args.paranoid:
                    kw["paranoid"] = True
                app.apply_one(
                    args.name, args.dry_run, args.force,
                    args.verify, args.install_deps, **kw,
                )
            else:
                ap.print_help()

        case "audit":
            if args.preset:
                preset_mods = PRESETS.get(args.preset, [])
                audit_mods  = [
                    m for m in preset_mods
                    if app.modules[m].info.kind in AUDIT_KINDS
                ]
                if not audit_mods:
                    print(f"preset {args.preset!r} contains no audit modules "
                          "(did you mean 'apply --preset'?)")
                    sys.exit(1)
                for mname in audit_mods:
                    app.apply_one(
                        mname, args.dry_run, args.force,
                        install_deps=args.install_deps,
                    )
                    app._print()
            elif args.name:
                if args.name not in app.modules:
                    print(f"unknown module: {args.name!r}")
                    sys.exit(1)
                mod = app.modules[args.name]
                if mod.info.kind not in AUDIT_KINDS:
                    print(f"{args.name!r} is a hardening module – use 'apply'")
                    sys.exit(1)
                ok, msg = mod.apply(
                    dry=args.dry_run, force=args.force,
                    install_deps=args.install_deps,
                )
                if not args.quiet:
                    icon = "✓" if ok else "✗"
                    print(f"\n{icon} {msg}")
                if not ok:
                    sys.exit(1)
            else:
                aup.print_help()

        case "revert":
            app.revert(args.module)

        case _:
            parser.print_help()


if __name__ == "__main__":
    main()
