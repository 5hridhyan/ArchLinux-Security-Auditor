#  SIGNAL HANDLING
#  _interrupted is reset at the *start* of each Module.apply() call so that
#  a Ctrl-c during one preset module does not poison subsequent modules.

_interrupted: bool = False

def _signal_handler(sig: int, frame: Any) -> None:
    global _interrupted
    _interrupted = True
    print("\n\n⚠️  interrupted – rolling back current module", file=sys.stderr)

signal.signal(signal.SIGINT,  _signal_handler)
signal.signal(signal.SIGTERM, _signal_handler)


#  SUBPROCESS HELPER

class RunResult:
    """Thin, immutable wrapper around CompletedProcess."""
    __slots__ = ("_rc", "_out", "_err", "_cmd")

    def __init__(self, returncode: int, stdout: str, stderr: str, cmd: List[str]):
        self._rc  = returncode
        self._out = stdout  or ""
        self._err = stderr  or ""
        self._cmd = cmd

    @property
    def ok(self) -> bool:         return self._rc == 0
    @property
    def returncode(self) -> int:  return self._rc
    @property
    def stdout(self) -> str:      return self._out
    @property
    def stderr(self) -> str:      return self._err
    @property
    def stdout_lines(self) -> List[str]:
        return [l for l in self._out.splitlines() if l.strip()]

    def __repr__(self) -> str:
        return f"RunResult(rc={self._rc}, cmd={self._cmd[0]!r})"


def run_cmd(
    cmd: List[str],
    *,
    module:       str  = "core",
    log_failure:  bool = True,
    quiet:        bool = False,
    no_color:     bool = False,
    timeout:      int  = 120,
    input_text:   Optional[str] = None,
    env:          Optional[Dict[str, str]] = None,
    cwd:          Optional[str] = None,
) -> RunResult:
    """
    Run a subprocess, always capturing stdout+stderr.
    Never raises on non-zero exit. On error, logs command + stderr snippet.
    Returns RunResult with returncode=-1 on OS/timeout errors.
    """
    import subprocess
    try:
        cp = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
            input=input_text,
            env=env,
            cwd=cwd,
        )
        r = RunResult(cp.returncode, cp.stdout, cp.stderr, cmd)
        if not r.ok and log_failure:
            snip = r.stderr.strip()[:300] or r.stdout.strip()[:300] or "(no output)"
            log_action(module, f"{cmd[0]!r} exited {r.returncode}: {snip}",
                       "warning", quiet, no_color)
        return r
    except __import__("subprocess").TimeoutExpired:
        log_action(module, f"{cmd[0]!r} timed out after {timeout}s", "error", quiet, no_color)
        return RunResult(-1, "", "timeout", cmd)
    except FileNotFoundError:
        log_action(module, f"command not found: {cmd[0]!r}", "error", quiet, no_color)
        return RunResult(-1, "", "not found", cmd)
    except OSError as exc:
        log_action(module, f"OS error running {cmd[0]!r}: {exc}", "error", quiet, no_color)
        return RunResult(-1, "", str(exc), cmd)


def vercmp(a: str, b: str) -> int:
    """
    Compare two pacman version strings via vercmp(8).
    Returns -1 (a<b), 0 (equal), 1 (a>b).
    Falls back to naive string compare if vercmp is unavailable.
    """
    r = run_cmd(["vercmp", a, b], log_failure=False, timeout=5)
    if r.returncode in (0, -1, 1):
        try:
            return int(r.stdout.strip())
        except ValueError:
            pass
    # Fallback: not accurate for epoch:version-rel, but better than nothing
    if a == b: return 0
    return -1 if a < b else 1


#  LOGGING / OUTPUT

_COLORS = {
    "error":   "\033[91m",
    "warning": "\033[93m",
    "info":    "\033[92m",
    "debug":   "\033[90m",
    "reset":   "\033[0m",
    "bold":    "\033[1m",
    "blue":    "\033[94m",
    "cyan":    "\033[96m",
}

def _c(text: str, style: str, no_color: bool) -> str:
    if no_color: return text
    return f"{_COLORS.get(style,'')}{text}{_COLORS['reset']}"


def log_action(
    module:   str,
    msg:      str,
    level:    str  = "info",
    quiet:    bool = False,
    no_color: bool = False,
) -> None:
    """Write to journald (best-effort) and stdout (unless quiet)."""
    import subprocess
    try:
        subprocess.run(
            ["logger", "-t", f"archguard[{module}]", f"{level}: {msg}"],
            capture_output=True, timeout=2,
        )
    except (OSError, subprocess.TimeoutExpired):
        pass

    if not quiet:
        prefix = f"[{module}] "
        print(_c(prefix + msg, level, no_color))


