        name="rkhunter", kind=ModKind.MALWARE,
        desc="Rootkit Hunter – scan for rootkits, backdoors, local exploits",
        version="4.0.0", author="archguard",
        deps=["rkhunter"], conflicts=[],
        reversible=False, risk="low",
    )

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            return True, "dry run: would run rkhunter --check"
        ok, msg = self.pre_check(force, kw.get("install_deps", False))
        if not ok:
            return False, msg

        # Update DB first; non-fatal
        run_cmd(["rkhunter", "--update", "--nocolors"],
                module=self.info.name, quiet=self.quiet,
                no_color=self.no_color, timeout=120, log_failure=False)

        r = run_cmd(
            ["rkhunter", "--check", "--skip-keypress",
             "--report-warnings-only", "--nocolors"],
            module=self.info.name, quiet=self.quiet, no_color=self.no_color,
            log_failure=False, timeout=300,
        )
        output = r.stdout + r.stderr
        save_report("rkhunter", output)

        # rkhunter --report-warnings-only: output contains only warning lines
        # returncode 0 = clean, 1 = warnings found, anything else = error
        if r.returncode not in (0, 1):
            self.emit("warning", f"rkhunter exited with unexpected code {r.returncode}",
                      output[:500])
            self.state.save_findings(self.findings)
            return False, f"rkhunter error (exit {r.returncode})"

        # Parse actual warning lines (lines containing "Warning:")
        warning_lines = [l for l in output.splitlines()
                         if "Warning:" in l or "warning:" in l.lower()]

        if warning_lines:
            for w in warning_lines:
                self.emit("warning", w.strip(),
                          remediation="Investigate with: rkhunter --check --rwo")
            self.state.save_findings(self.findings)
            return False, f"{len(warning_lines)} warning(s) – see report"

        self.emit("info", "rkhunter scan: no warnings")
        self.state.save_findings(self.findings)
        return True, "clean"

    def status(self): return ModStatus.UNKNOWN


