class SystemdSandbox(Module):
    info = ModInfo(
        name="systemd_sandbox", kind=ModKind.SANDBOX,
        desc="add ProtectSystem/PrivateTmp/NoNewPrivileges to systemd services",
        version="4.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=True, risk="high",
    )

    TARGETS = [
        "systemd-networkd.service", "systemd-resolved.service",
        "cups.service", "bluetooth.service", "avahi-daemon.service",
        "colord.service", "geoclue.service",
    ]

    _OVERRIDE = """\
[Service]
# archguard sandbox overlay  (generated {ts})
ProtectSystem           = strict
ProtectHome             = yes
PrivateTmp              = yes
PrivateDevices          = yes
NoNewPrivileges         = yes
RestrictSUIDSGID        = yes
ProtectKernelTunables   = yes
ProtectKernelModules    = yes
ProtectKernelLogs       = yes
ProtectControlGroups    = yes
RestrictRealtime        = yes
RestrictNamespaces      = yes
LockPersonality         = yes
MemoryDenyWriteExecute  = yes
"""

    def __init__(self, *a, **kw):
        super().__init__(*a, **kw)
        self._available: List[str] = []

    def pre_check(self, force=False, install_deps=False):
        ok, msg = super().pre_check(force, install_deps)
        if not ok:
            return ok, msg
        self._available = [
            s for s in self.TARGETS
            if run_cmd(["systemctl", "cat", s], log_failure=False).ok
        ]
        if not self._available:
            return False, "no target services found on this system"
        return True, "ok"

    def gen_config(self, **_) -> Dict[str, str]:
        if not self._pre_checked:
            return {}   # safe for dry-run without pre_check
        ts  = datetime.now().strftime("%Y-%m-%d %H:%M")
        out = {}
        for svc in self._available:
            f = Path(f"/etc/systemd/system/{svc}.d/archguard-sandbox.conf")
            if not f.exists():
                out[str(f)] = self._OVERRIDE.format(ts=ts)
        return out

    def apply(self, dry=False, force=False, verify=False, **kw):
        ok, msg = super().apply(dry, force, verify, **kw)
        if ok and not dry:
            run_cmd(["systemctl", "daemon-reload"],
                    module=self.info.name, quiet=self.quiet, no_color=self.no_color)
            if force:
                for svc in self._available:
                    run_cmd(["systemctl", "try-restart", svc],
                            module=self.info.name, log_failure=False,
                            quiet=self.quiet, no_color=self.no_color)
                log_action(self.info.name, "sandbox overrides applied and services restarted",
                           quiet=self.quiet, no_color=self.no_color)
            else:
                log_action(
                    self.info.name,
                    "overrides written – restart services manually or use --force",
                    "warning", self.quiet, self.no_color,
                )
        return ok, msg

    def status(self):
        existing = [
            s for s in self.TARGETS
            if run_cmd(["systemctl", "cat", s], log_failure=False).ok
        ]
        if not existing:
            return ModStatus.UNKNOWN
        found = sum(
            1 for s in existing
            if Path(f"/etc/systemd/system/{s}.d/archguard-sandbox.conf").exists()
        )
        if found == len(existing): return ModStatus.APPLIED
        if found > 0:              return ModStatus.PARTIAL
        return ModStatus.UNKNOWN





