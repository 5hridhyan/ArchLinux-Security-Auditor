@dataclass
class Finding:
    """A single security finding emitted by an audit module."""
    severity:    str         # info / warning / critical
    module:      str
    title:       str
    detail:      str        = ""
    remediation: str        = ""
    when:        str        = field(default_factory=lambda: datetime.now().isoformat())
    cve:         List[str]  = field(default_factory=list)

    def to_dict(self) -> Dict[str, Any]:
        return {k: v for k, v in self.__dict__.items()}

    @classmethod
    def from_dict(cls, d: Dict[str, Any]) -> "Finding":
        return cls(**{k: v for k, v in d.items() if k in cls.__dataclass_fields__})


#  PERSISTENT STATE  (schema v4, forward-compatible)

class State:
    STATE_DIR      = Path("/var/lib/archguard")
    STATE_FILE     = STATE_DIR / "state.json"
    FINDINGS_FILE  = STATE_DIR / "findings.json"
    SCHEMA_VERSION = 4

    def __init__(self) -> None:
        self.STATE_DIR.mkdir(parents=True, exist_ok=True)
        self.data:     Dict[str, List[Dict]] = self._load_state()
        self.findings: List[Dict]            = self._load_findings()

    #  state I/O 

    def _load_state(self) -> Dict[str, List[Dict]]:
        if not self.STATE_FILE.exists():
            return {}
        try:
            raw = json.loads(self.STATE_FILE.read_text())
        except (json.JSONDecodeError, OSError) as exc:
            _log.warning("cannot load state (%s): %s – starting fresh", self.STATE_FILE, exc)
            return {}
        if isinstance(raw, dict) and "_schema_version" in raw:
            v = raw["_schema_version"]
            if v != self.SCHEMA_VERSION:
                _log.warning("state schema v%s, expected v%s – migrating", v, self.SCHEMA_VERSION)
            return raw.get("modules", {})
        return raw  # legacy flat format

    def _save_state(self) -> None:
        """Atomic write of state.json via tmp-rename."""
        payload = json.dumps(
            {"_schema_version": self.SCHEMA_VERSION, "modules": self.data},
            indent=2,
        )
        tmp = self.STATE_FILE.with_suffix(".tmp")
        try:
            tmp.write_text(payload)
            tmp.rename(self.STATE_FILE)
        except OSError as exc:
            _log.error("cannot save state: %s", exc)

    def add(self, module: str, path: str, backup: str, checksum: str = "") -> None:
        rec: Dict[str, Any] = {
            "module": module, "path": path, "backup": backup,
            "when": datetime.now().isoformat(),
        }
        if checksum:
            rec["checksum"] = checksum
        self.data.setdefault(module, []).append(rec)
        self._save_state()

    def get(
        self,
        module: Optional[str] = None,
        since:  Optional[datetime] = None,
        limit:  Optional[int] = None,
    ) -> List[Dict]:
        recs = (
            list(self.data.get(module, []))
            if module
            else [r for ml in self.data.values() for r in ml]
        )
        recs.sort(key=lambda r: r["when"], reverse=True)
        if since:
            recs = [r for r in recs if datetime.fromisoformat(r["when"]) >= since]
        if limit:
            recs = recs[:limit]
        return recs

    def remove(self, module: str, path: str, backup: str) -> None:
        if module in self.data:
            self.data[module] = [
                r for r in self.data[module]
                if not (r["path"] == path and r["backup"] == backup)
            ]
            if not self.data[module]:
                del self.data[module]
            self._save_state()

    #  findings I/O

    def _load_findings(self) -> List[Dict]:
        if not self.FINDINGS_FILE.exists():
            return []
        try:
            return json.loads(self.FINDINGS_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            return []

    def save_findings(self, new_findings: List[Finding]) -> None:
        """Merge new findings, keep last 30 days, atomic write."""
        cutoff = (datetime.now() - timedelta(days=30)).isoformat()
        merged = [f for f in self.findings if f.get("when", "9999") >= cutoff]
        merged += [f.to_dict() for f in new_findings]
        tmp = self.FINDINGS_FILE.with_suffix(".tmp")
        try:
            tmp.write_text(json.dumps(merged, indent=2))
            tmp.rename(self.FINDINGS_FILE)
            self.findings = merged
        except OSError as exc:
            _log.warning("cannot save findings: %s", exc)


#  BACKUP MANAGER

class BackupKeeper:
    BACKUP_DIR = Path("/var/backups/archguard")

    def __init__(self, state: State) -> None:
        self.dir = self.BACKUP_DIR
        self.dir.mkdir(parents=True, exist_ok=True)
        self.state = state

    @staticmethod
    def _file_hash(path: Path) -> str:
        sha = hashlib.sha256()
        try:
            with open(path, "rb") as f:
                for block in iter(lambda: f.read(65536), b""):
                    sha.update(block)
        except OSError as exc:
            raise OSError(f"cannot hash {path}: {exc}") from exc
        return sha.hexdigest()

    @staticmethod
    def _copy_with_perms(src: Path, dst: Path) -> None:
        """Copy file preserving mode and uid/gid."""
        shutil.copy2(src, dst)
        st = src.stat()
        os.chown(dst, st.st_uid, st.st_gid)
        os.chmod(dst, st.st_mode)

    def create(self, path: str, module: str) -> Optional[Path]:
        """Backup a file; returns backup path or None on failure."""
        src = Path(path)
        if not src.exists():
            return None
        stamp = datetime.now().strftime("%Y%m%d_%H%M%S_%f")
        dest  = self.dir / f"{src.name}.{module}.{stamp}.bak"
        try:
            self._copy_with_perms(src, dest)
            h = self._file_hash(dest)
            self.state.add(module, path, str(dest), h)
            return dest
        except (OSError, shutil.Error) as exc:
            _log.error("backup failed for %s: %s", path, exc)
            return None

    def restore(self, path: str, backup_path: Path, expected_hash: str = "") -> bool:
        """Restore a backup file with optional hash verification."""
        if expected_hash:
            try:
                actual = self._file_hash(backup_path)
            except OSError as exc:
                _log.error("cannot hash %s: %s", backup_path, exc)
                return False
            if actual != expected_hash:
                log_action(
                    "backup",
                    f"hash mismatch {backup_path.name}: expected {expected_hash[:12]}… got {actual[:12]}…",
                    "error",
                )
                return False
        try:
            dest = Path(path)
            dest.parent.mkdir(parents=True, exist_ok=True)
            self._copy_with_perms(backup_path, dest)
            return True
        except (OSError, shutil.Error) as exc:
            _log.error("restore failed for %s: %s", path, exc)
            return False


#  ATOMIC FILE WRITE

def atomic_write(
    path:      Path,
    content:   str,
    reference: Optional[Path],
    no_color:  bool = False,
) -> bool:
    """
    Write content to path atomically via tempfile+rename.
    Permissions are inherited from: reference → existing file → 0o644 root:root.
    """
    tmp_path: Optional[Path] = None
    try:
        fd, raw_tmp = tempfile.mkstemp(dir=path.parent, prefix=path.name + ".tmp")
        tmp_path = Path(raw_tmp)
        with os.fdopen(fd, "w") as f:
            f.write(content)

        ref = (
            reference if (reference and reference.exists())
            else path if path.exists()
            else None
        )
        if ref:
            st = ref.stat()
            os.chown(tmp_path, st.st_uid, st.st_gid)
            os.chmod(tmp_path, st.st_mode)
        else:
            os.chown(tmp_path, 0, 0)
            os.chmod(tmp_path, 0o644)

        tmp_path.rename(path)
        return True
    except (OSError, PermissionError) as exc:
        log_action("atomic_write", f"failed writing {path}: {exc}", "error", no_color=no_color)
        if tmp_path and tmp_path.exists():
            try:
                tmp_path.unlink()
            except OSError:
                pass
        return False


#  DIFF VIEWER

import subprocess
import difflib

def show_diff(old: str, new: str, path: str, verbose: bool, no_color: bool) -> None:
    if not verbose:
        return
    diff = list(difflib.unified_diff(
        old.splitlines(keepends=True),
        new.splitlines(keepends=True),
        fromfile=f"{path} (current)",
        tofile=f"{path} (proposed)",
    ))
    if not diff:
        return
    print("\n" + "─" * 64)
    print(_c(f"Diff: {path}", "bold", no_color))
    print("─" * 64)
    for line in diff:
        if no_color:
            print(line, end="")
        elif line.startswith("+") and not line.startswith("+++"):
            print(f"\033[92m{line}\033[0m", end="")
        elif line.startswith("-") and not line.startswith("---"):
            print(f"\033[91m{line}\033[0m", end="")
        elif line.startswith("@"):
            print(f"\033[94m{line}\033[0m", end="")
        else:
            print(line, end="")
    print("─" * 64 + "\n")


#  BOOTLOADER DETECTION

def detect_bootloader() -> Tuple[Optional[str], Optional[Path]]:
    """
    Detect active bootloader.
    Returns (name, config_path) where config_path may be None.
    """
    if Path("/boot/grub/grub.cfg").exists():
        return "grub", Path("/boot/grub/grub.cfg")
    if Path("/boot/loader/loader.conf").exists():
        return "systemd-boot", Path("/boot/loader")
    if Path("/efi/loader/loader.conf").exists():
        return "systemd-boot", Path("/efi/loader")
    efi_dirs = [Path("/efi/EFI"), Path("/boot/EFI"), Path("/esp/EFI")]
    for d in efi_dirs:
        if d.is_dir() and list(d.glob("*/*.efi")):
            return "efistub", d
    return None, None


#  REPORT & CACHE HELPERS


LOG_DIR   = Path("/var/log/archguard")
CACHE_DIR = Path("/var/cache/archguard")


def save_report(module: str, content: str) -> Path:
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    path  = LOG_DIR / f"{module}.{stamp}.log"
    try:
        path.write_text(content)
    except OSError as exc:
        _log.warning("cannot write report for %s: %s", module, exc)
    return path


def cache_get(key: str, ttl: int = 3600) -> Optional[str]:
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    safe = re.sub(r"[^a-z0-9_\-]", "_", key.lower())
    p    = CACHE_DIR / f"{safe}.cache"
    if not p.exists():
        return None
    if time.time() - p.stat().st_mtime > ttl:
        return None
    try:
        return p.read_text()
    except OSError:
        return None


def cache_put(key: str, value: str) -> None:
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    safe = re.sub(r"[^a-z0-9_\-]", "_", key.lower())
    p    = CACHE_DIR / f"{safe}.cache"
    try:
        p.write_text(value)
    except OSError as exc:
        _log.warning("cache write failed for %s: %s", key, exc)


#  BASE MODULE

class Module:
    info = ModInfo(
        name="base", kind=ModKind.AUDIT,
        desc="base – should not appear in listings",
        version="4.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def __init__(
        self,
        state:    State,
        quiet:    bool = False,
        verbose:  bool = False,
        no_color: bool = False,
    ) -> None:
        self.state     = state
        self.backups   = BackupKeeper(state)
        self.quiet     = quiet
        self.verbose   = verbose
        self.no_color  = no_color
        self._pre_checked = False
        self.findings: List[Finding] = []

    # dependency management

    def pre_check(self, force: bool = False, install_deps: bool = False) -> Tuple[bool, str]:
        missing = [p for p in self.info.deps
                   if not run_cmd(["pacman", "-Q", p], log_failure=False).ok]

        if missing:
            if install_deps:
                log_action(self.info.name, f"installing: {', '.join(missing)}",
                           quiet=self.quiet, no_color=self.no_color)
                for pkg in missing:
                    r = run_cmd(["pacman", "-S", "--noconfirm", "--needed", pkg],
                                module=self.info.name, quiet=self.quiet,
                                no_color=self.no_color, timeout=300)
                    if not r.ok:
                        return False, f"failed to install {pkg!r}: {r.stderr.strip()[:200]}"
            else:
                return False, f"missing: {', '.join(missing)} (pass --install-deps)"

        for pkg in self.info.conflicts:
            if run_cmd(["pacman", "-Q", pkg], log_failure=False).ok:
                if not force:
                    return False, f"conflicting package {pkg!r} installed (use --force)"
                log_action(self.info.name, f"conflict {pkg!r} present – continuing (--force)",
                           "warning", self.quiet, self.no_color)

        self._pre_checked = True
        return True, "ok"

    #  config generation (override in hardening subclasses) 

    def gen_config(self, **kwargs) -> Dict[str, str]:
        """Return {path: content}. Pure – no side-effects, no subprocess."""
        return {}

    # apply: backup → write → verify 

    def apply(
        self,
        dry:          bool = False,
        force:        bool = False,
        verify:       bool = False,
        install_deps: bool = False,
        **kw,
    ) -> Tuple[bool, str]:
        global _interrupted
        _interrupted = False   # reset PER-APPLY; no cross-module bleed

        if not dry:
            ok, msg = self.pre_check(force, install_deps)
            if not ok:
                return False, f"pre-check: {msg}"

        configs = self.gen_config(**kw)
        if not configs:
            return True, "nothing to do"

        applied: List[Tuple[str, Optional[str], bool]] = []
        changed = False

        for path, new_content in configs.items():
            if _interrupted:
                log_action(self.info.name, "interrupted – rolling back",
                           "warning", self.quiet, self.no_color)
                self._rollback(applied)
                return False, "interrupted by user"

            p = Path(path)
            old_content = ""
            if p.exists():
                try:
                    old_content = p.read_text()
                except OSError as exc:
                    log_action(self.info.name, f"cannot read {path}: {exc}",
                               "warning", self.quiet, self.no_color)
                    continue

            if old_content == new_content:
                continue

            changed = True
            show_diff(old_content, new_content, path, self.verbose, self.no_color)

            if dry:
                print(f"  {_c('would write','cyan', self.no_color)}: {path}")
                continue

            if not force:
                try:
                    resp = input(f"  Apply changes to {path}? [y/N] ")
                except EOFError:
                    resp = "n"
                if resp.strip().lower() != "y":
                    log_action(self.info.name, f"skipped {path}", quiet=self.quiet,
                               no_color=self.no_color)
                    continue

            #  backup
            backup_str: Optional[str] = None
            is_new = False

            if p.exists():
                b = self.backups.create(path, self.info.name)
                if b is None:
                    log_action(self.info.name, f"backup failed for {path} – aborting",
                               "error", self.quiet, self.no_color)
                    self._rollback(applied)
                    return False, f"backup failed: {path}"
                backup_str = str(b)
                log_action(self.info.name, f"backup → {b.name}",
                           quiet=self.quiet, no_color=self.no_color)
            else:
                self.state.add(self.info.name, path, "NEW_FILE")
                is_new = True

            #  atomic writ
            ref = Path(backup_str) if backup_str else None
            if not atomic_write(p, new_content, ref, self.no_color):
                self._rollback(applied)
                return False, f"write failed: {path}"

            log_action(self.info.name, f"wrote {path}",
                       quiet=self.quiet, no_color=self.no_color)
            applied.append((path, backup_str, is_new))

        if not changed:
            return True, "already up-to-date"

        if verify and not dry:
            ok, vmsg = self.verify()
            lvl = "info" if ok else "warning"
            log_action(self.info.name, f"verify: {vmsg}", lvl, self.quiet, self.no_color)

        return True, "module applied"

    # rollback 

    def _rollback(self, changes: List[Tuple[str, Optional[str], bool]]) -> None:
        """Undo a list of (path, backup_str, is_new) in reverse order."""
        for path, backup_str, is_new in reversed(changes):
            if is_new:
                try:
                    Path(path).unlink(missing_ok=True)
                    log_action(self.info.name, f"rollback: removed {path}",
                               quiet=self.quiet, no_color=self.no_color)
                except OSError as exc:
                    log_action(self.info.name, f"rollback: cannot remove {path}: {exc}",
                               "error", self.quiet, self.no_color)
                finally:
                    self.state.remove(self.info.name, path, "NEW_FILE")
            elif backup_str:
                bp = Path(backup_str)
                if bp.exists():
                    if self.backups.restore(path, bp):
                        log_action(self.info.name, f"rollback: restored {path}",
                                   quiet=self.quiet, no_color=self.no_color)
                    self.state.remove(self.info.name, path, backup_str)
                else:
                    log_action(self.info.name,
                               f"rollback: backup missing for {path}", "error",
                               self.quiet, self.no_color)

    #  revert (post-hoc undo from state)

    def revert(self) -> Tuple[bool, str]:
        if not self.info.reversible:
            return False, "module is not reversible"
        changes = self.state.get(self.info.name)
        if not changes:
            return False, "no recorded changes"

        reverted = 0
        for rec in sorted(changes, key=lambda r: r["when"], reverse=True):
            path, backup = rec["path"], rec["backup"]
            if backup == "NEW_FILE":
                try:
                    Path(path).unlink(missing_ok=True)
                    log_action(self.info.name, f"removed {path}",
                               quiet=self.quiet, no_color=self.no_color)
                    reverted += 1
                    self.state.remove(self.info.name, path, backup)
                except OSError as exc:
                    log_action(self.info.name, f"cannot remove {path}: {exc}",
                               "error", self.quiet, self.no_color)
            else:
                bp = Path(backup)
                if not bp.exists():
                    log_action(self.info.name, f"backup missing: {bp}",
                               "error", self.quiet, self.no_color)
                    continue
                h = rec.get("checksum", "")
                if self.backups.restore(path, bp, h):
                    log_action(self.info.name, f"restored {path}",
                               quiet=self.quiet, no_color=self.no_color)
                    reverted += 1
                    self.state.remove(self.info.name, path, backup)
                else:
                    log_action(self.info.name, f"restore failed: {path}",
                               "error", self.quiet, self.no_color)

        return (True, f"reverted {reverted} change(s)") if reverted else (False, "nothing reverted")

    def status(self) -> ModStatus:
        return ModStatus.UNKNOWN

    def verify(self) -> Tuple[bool, str]:
        return True, "ok"

    # finding helpers

    def emit(
        self,
        severity:    str,
        title:       str,
        detail:      str = "",
        remediation: str = "",
        cve:         Optional[List[str]] = None,
    ) -> Finding:
        f = Finding(
            severity=severity, module=self.info.name,
            title=title, detail=detail, remediation=remediation,
            cve=cve or [],
        )
        self.findings.append(f)
        if not self.quiet:
            icons = {"critical": "🔴", "warning": "🟡", "info": "🔵"}
            icon  = icons.get(severity, "•") if not self.no_color else f"[{severity.upper()}]"
            print(f"  {icon} {_c(title, severity, self.no_color)}")
            if self.verbose and detail:
                for line in detail.splitlines()[:10]:
                    print(f"       {line}")
            if self.verbose and remediation:
                print(f"       {_c('→','cyan',self.no_color)} {remediation}")
        return f


