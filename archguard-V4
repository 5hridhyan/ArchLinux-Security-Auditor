                        self.emit("info", "Secure Boot ENABLED (via EFI var) ✓")
                    else:
                        self.emit("warning", "Secure Boot DISABLED",
                                  remediation="Enable in UEFI firmware settings")
                except OSError:
                    self.emit("info", "Secure Boot status unknown (EFI var unreadable)")
            else:
                self.emit("info", "mokutil unavailable – install to check Secure Boot")

        # Check if UEFI setup mode (keys not enrolled)
        sm_var = Path(
            "/sys/firmware/efi/vars/"
            "SetupMode-8be4df61-93ca-11d2-aa0d-00e098032b8c/data"
        )
        if sm_var.exists():
            try:
                sm = sm_var.read_bytes()
                if sm and sm[0] == 1:
                    self.emit("critical", "UEFI in Setup Mode – no keys enrolled",
                              remediation="Enroll platform keys: mokutil --import MOK.der")
            except OSError:
                pass

        self.state.save_findings(self.findings)
        return True, "Secure Boot check completed"

    def status(self): return ModStatus.UNKNOWN


#  AUDIT MODULE: TIME SYNCHRONISATION

class TimeSyncAudit(Module):
    info = ModInfo(
        name="timesync", kind=ModKind.AUDIT,
        desc="verify NTP/chrony/timesyncd is active and clock is synchronised",
        version="4.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    NTP_SERVICES = ("systemd-timesyncd", "chronyd", "ntpd", "openntpd", "chrony")

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            return True, "dry run: would check NTP services and clock sync"

        synced = False
        for svc in self.NTP_SERVICES:
            r = run_cmd(["systemctl", "is-active", svc], log_failure=False)
            if r.ok and r.stdout.strip() == "active":
                self.emit("info", f"time sync active via {svc} ✓")
                synced = True
                break

        if not synced:
            self.emit("critical", "no time sync service is active",
                      remediation=(
                          "systemctl enable --now systemd-timesyncd\n"
                          "or: pacman -S chrony && systemctl enable --now chronyd"
                      ))

        # timedatectl for detailed status
        tdc = run_cmd(["timedatectl", "show"], log_failure=False)
        if tdc.ok:
            props: Dict[str, str] = {}
            for line in tdc.stdout_lines:
                if "=" in line:
                    k, _, v = line.partition("=")
                    props[k.strip()] = v.strip()

            ntp_sync = props.get("NTPSynchronized", "no").lower()
            if ntp_sync == "yes":
                self.emit("info", "clock is NTP-synchronised ✓")
            else:
                self.emit("warning", "clock is NOT NTP-synchronised",
                          remediation="Check: timedatectl status")

            rtc_utc = props.get("LocalRTC", "yes").lower()
            if rtc_utc == "no":
                self.emit("info", "RTC set to UTC ✓")
            else:
                self.emit("warning", "RTC set to local time (can cause DST issues)",
                          remediation="timedatectl set-local-rtc 0")

        self.state.save_findings(self.findings)
        return True, "time sync check completed"

    def status(self): return ModStatus.UNKNOWN


#  AUDIT MODULE: MEMORY & RUNTIME SECURITY FEATURES

class MemSecurity(Module):
    info = ModInfo(
        name="mem_security", kind=ModKind.KERNEL,
        desc="check ASLR, PIE, stack canaries, NX bit, SMEP/SMAP, Spectre/Meltdown",
        version="4.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            return True, "dry run: would check memory security features"

        # ASLR
        aslr = Path("/proc/sys/kernel/randomize_va_space")
        if aslr.exists():
            val = aslr.read_text().strip()
            if val == "2":
                self.emit("info", "ASLR: full randomisation (2) ✓")
            elif val == "1":
                self.emit("warning", "ASLR: partial only (1)",
                          remediation="sysctl kernel.randomize_va_space=2")
            else:
                self.emit("critical", "ASLR disabled (0)",
                          remediation="sysctl kernel.randomize_va_space=2")

        # CPU vulnerabilities (from sysfs)
        vuln_dir = Path("/sys/devices/system/cpu/vulnerabilities")
        if vuln_dir.is_dir():
            for vf in sorted(vuln_dir.iterdir()):
                status = vf.read_text().strip()
                if "Not affected" in status or "Mitigation" in status:
                    self.emit("info", f"CPU {vf.name}: {status}")
                else:
                    self.emit("warning", f"CPU {vf.name}: {status}",
                              remediation="Ensure kernel mitigations are not disabled at boot")

        # NX bit
        r = run_cmd(["grep", "-m1", "nx", "/proc/cpuinfo"], log_failure=False)
        if r.ok and "nx" in r.stdout:
            self.emit("info", "CPU NX/XD bit: supported ✓")
        else:
            self.emit("warning", "CPU NX/XD bit: not reported (may be virtualised)")

        # Check for kernel lockdown
        lockdown = Path("/sys/kernel/security/lockdown")
        if lockdown.exists():
            val = lockdown.read_text().strip()
            self.emit("info", f"kernel lockdown: {val}")
        else:
            self.emit("info", "kernel lockdown: not available (optional CONFIG_SECURITY_LOCKDOWN)")

        # execshield / grsecurity indicators
        dmesg_r = run_cmd(["dmesg"], log_failure=False, timeout=10)
        if "grsecurity" in dmesg_r.stdout.lower():
            self.emit("info", "grsecurity kernel detected")

        self.state.save_findings(self.findings)
        return True, "memory security check completed"

    def status(self): return ModStatus.UNKNOWN



#  AUDIT MODULE: PASSWORD POLICY

class PasswordPolicy(Module):
    info = ModInfo(
        name="passwd_policy", kind=ModKind.ACCESS,
        desc="check PAM password quality, aging, shadow file permissions",
        version="4.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            return True, "dry run: would audit PAM and shadow settings"

        # /etc/shadow permissions
        shadow = Path("/etc/shadow")
        if shadow.exists():
            mode = shadow.stat().st_mode & 0o777
            if mode <= 0o640:
                self.emit("info", f"/etc/shadow permissions: {oct(mode)} ✓")
            else:
                self.emit("critical", f"/etc/shadow too permissive: {oct(mode)}",
                          remediation="chmod 000 /etc/shadow  (or 640 if shadow group needed)")

        # Check for accounts with empty passwords
        r = run_cmd(["awk", "-F:", "($2==\"\"){print $1}", "/etc/shadow"],
                    log_failure=False)
        for user in r.stdout_lines:
            if user.strip():
                self.emit("critical", f"account with empty password: {user.strip()}",
                          remediation=f"passwd {user.strip()}  # set a password")

        # Check for UID 0 accounts other than root
        r2 = run_cmd(["awk", "-F:", "($3==0){print $1}", "/etc/passwd"],
                     log_failure=False)
        uid0 = [u.strip() for u in r2.stdout_lines if u.strip() != "root"]
        for u in uid0:
            self.emit("critical", f"non-root account with UID 0: {u}",
                      remediation=f"usermod -u <newuid> {u}  # assign a non-zero UID")

        # PAM pwquality
        pam_passwd = Path("/etc/pam.d/passwd")
        if pam_passwd.exists():
            try:
                content = pam_passwd.read_text()
                if "pwquality" in content or "cracklib" in content:
                    self.emit("info", "PAM password quality enforcement present ✓")
                else:
                    self.emit("warning", "no PAM password quality module configured",
                              remediation="Install libpwquality and add to /etc/pam.d/passwd")
            except OSError:
                pass

        # Password aging via chage (sample root account)
        chage = run_cmd(["chage", "-l", "root"], log_failure=False)
        if chage.ok:
            for line in chage.stdout_lines:
                if "Maximum number of days" in line:
                    m = re.search(r":\s*(\d+|-1|never)", line, re.IGNORECASE)
                    if m and m.group(1) in ("-1", "99999", "never"):
                        self.emit("info", "root password: no expiry (normal for root)")

        self.state.save_findings(self.findings)
        return True, "password policy check completed"

    def status(self): return ModStatus.UNKNOWN



