class LogAudit(Module):
    info = ModInfo(
        name="log_audit", kind=ModKind.AUDIT,
        desc="scan journal for auth failures, SSH probes, OOM, crashes (last 24h)",
        version="4.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def _journal_grep(self, pattern: str, since: str = "24 hours ago") -> List[str]:
        """
        Grep journal with systemd's native --grep (systemd ≥ 249).
        Falls back to piped grep for older versions.
        """
        r = run_cmd(
            ["journalctl", "-q", "--since", since,
             "--grep", pattern, "--no-pager"],
            log_failure=False, timeout=30,
        )
        # journalctl --grep: rc=0 matches, rc=1 no matches (no stderr), else error
        if r.returncode in (0, 1) and not r.stderr.strip():
            return r.stdout_lines

        # Fallback: dump journal and grep in Python
        full = run_cmd(
            ["journalctl", "-q", "--since", since, "--no-pager"],
            log_failure=False, timeout=60,
        )
        return [l for l in full.stdout_lines if re.search(pattern, l, re.IGNORECASE)]

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            return True, "dry run: would scan last 24h of journal"

        checks = [
            (r"sudo.*authentication failure",    "failed sudo attempts",     "warning"),
            (r"sshd.*Failed password",           "failed SSH password logins", "warning"),
            (r"sshd.*Invalid user",              "SSH invalid-user probes",  "warning"),
            (r"sshd.*Accepted publickey",        "SSH public-key logins",    "info"),
            (r"sshd.*Accepted password",         "SSH password logins",      "warning"),
            (r"unit.*entered failed state",      "systemd service failures", "warning"),
            (r"Out of memory|OOM killer",        "OOM kills",                "critical"),
            (r"segfault",                        "segfaults",                "info"),
            (r"kernel: BUG",                     "kernel BUG assertions",    "critical"),
            (r"kernel: WARNING",                 "kernel warnings",          "warning"),
            (r"audit.*denied",                   "AppArmor/SELinux denials", "warning"),
            (r"pam_unix.*authentication failure","PAM auth failures",        "warning"),
            (r"CRON.*CMD",                       "cron executions",          "info"),
        ]

        all_output: List[str] = []
        for pattern, label, severity in checks:
            lines = self._journal_grep(pattern)
            all_output.extend(lines)
            if lines:
                detail = "\n".join(lines[:10])
                if len(lines) > 10:
                    detail += f"\n…and {len(lines)-10} more"
                self.emit(severity, f"{len(lines)} {label} in last 24h", detail)
            else:
                if severity in ("critical", "warning"):
                    self.emit("info", f"no {label}")

        save_report("log_audit", "\n".join(all_output))
        self.state.save_findings(self.findings)
        return True, "log audit completed"

    def status(self): return ModStatus.UNKNOWN



