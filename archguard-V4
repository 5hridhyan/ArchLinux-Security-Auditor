class SSHAudit(Module):
    info = ModInfo(
        name="ssh_audit", kind=ModKind.AUDIT,
        desc="audit sshd_config for weak settings and legacy algorithms",
        version="4.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            return True, "dry run: would audit /etc/ssh/sshd_config"

        sshd = Path("/etc/ssh/sshd_config")
        if not sshd.exists():
            self.emit("info", "sshd_config not found – SSH server not installed")
            return True, "not installed"

        try:
            conf = sshd.read_text()
        except OSError as exc:
            return False, f"cannot read sshd_config: {exc}"

        def get(key: str) -> Optional[str]:
            m = re.search(rf"^\s*{re.escape(key)}\s+(\S+)",
                          conf, re.IGNORECASE | re.MULTILINE)
            return m.group(1).lower() if m else None

        # Key security settings
        checks = [
            ("PermitRootLogin",      lambda v: v in ("no", "prohibit-password"),
             "should be 'no' or 'prohibit-password'",
             "warning", "Set 'PermitRootLogin no' in sshd_config"),
            ("PasswordAuthentication", lambda v: v == "no",
             "should be 'no' (use key-based auth only)",
             "warning", "Set 'PasswordAuthentication no'"),
            ("PermitEmptyPasswords", lambda v: v == "no",
             "must be 'no'",
             "critical", "Set 'PermitEmptyPasswords no'"),
            ("X11Forwarding",        lambda v: v == "no",
             "should be 'no' to reduce attack surface",
             "info", "Set 'X11Forwarding no'"),
            ("MaxAuthTries",         lambda v: v.isdigit() and int(v) <= 4,
             "should be ≤ 4",
             "warning", "Set 'MaxAuthTries 3'"),
            ("LoginGraceTime",       lambda v: v.rstrip("ms") == "30" or (
                v.rstrip("s").isdigit() and int(v.rstrip("s")) <= 30),
             "should be ≤ 30s",
             "info", "Set 'LoginGraceTime 30'"),
            ("AllowAgentForwarding", lambda v: v == "no",
             "should be 'no' unless needed",
             "info", "Set 'AllowAgentForwarding no'"),
            ("AllowTcpForwarding",   lambda v: v == "no",
             "should be 'no' unless needed",
             "info", "Set 'AllowTcpForwarding no'"),
            ("UsePAM",               lambda v: v == "yes",
             "should be 'yes' for PAM integration",
             "warning", "Set 'UsePAM yes'"),
        ]

        for key, test, msg, severity, remediation in checks:
            val = get(key)
            if val is None:
                self.emit("info", f"{key}: not set (using sshd default)")
            elif test(val):
                self.emit("info", f"{key} = {val} ✓")
            else:
                self.emit(severity, f"{key} = {val!r} – {msg}",
                          remediation=remediation)

        # Weak cipher/mac/kex check
        weak_ciphers = ["arcfour", "des", "3des", "blowfish", "cast128",
                        "aes128-cbc", "aes192-cbc", "aes256-cbc"]
        ciphers = get("Ciphers") or ""
        bad = [w for w in weak_ciphers if w in ciphers]
        if bad:
            self.emit("critical", f"Weak SSH ciphers in use: {', '.join(bad)}",
                      remediation="Remove from Ciphers in sshd_config")

        # Authorised keys location
        ak = get("AuthorizedKeysFile")
        if ak and ".." in ak:
            self.emit("critical", f"AuthorizedKeysFile path contains '..': {ak}",
                      remediation="Use absolute paths for AuthorizedKeysFile")

        save_report("ssh_audit", "\n".join(f.title for f in self.findings))
        self.state.save_findings(self.findings)
        return True, "SSH audit completed"

    def status(self): return ModStatus.UNKNOWN


