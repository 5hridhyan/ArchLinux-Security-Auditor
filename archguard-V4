#  AUDIT MODULE: ARCH SECURITY ADVISORIES

class ArchSecurity(Module):
    info = ModInfo(
        name="archsec", kind=ModKind.COMPLIANCE,
        desc="cross-check installed packages against Arch Linux CVE tracker",
        version="4.0.0", author="archguard",
        deps=[], conflicts=[],
        reversible=False, risk="low",
    )

    CVE_URL   = "https://security.archlinux.org/all.json"
    CACHE_KEY = "archsec_cve_json"
    CACHE_TTL = 3600

    def _fetch(self) -> Optional[list]:
        cached = cache_get(self.CACHE_KEY, self.CACHE_TTL)
        if cached:
            try:
                return json.loads(cached)
            except json.JSONDecodeError:
                pass
        try:
            req = urllib.request.Request(
                self.CVE_URL,
                headers={"User-Agent": "archguard/4.0 security-scanner"},
            )
            with urllib.request.urlopen(req, timeout=30) as resp:
                raw = resp.read().decode()
            cache_put(self.CACHE_KEY, raw)
            return json.loads(raw)
        except (urllib.error.URLError, socket.timeout, OSError) as exc:
            log_action(self.info.name, f"network error: {exc}", "error",
                       self.quiet, self.no_color)
            return None
        except json.JSONDecodeError as exc:
            log_action(self.info.name, f"invalid CVE JSON: {exc}", "error",
                       self.quiet, self.no_color)
            return None

    def apply(self, dry=False, force=False, verify=False, **kw):
        if dry:
            return True, "dry run: would fetch from security.archlinux.org"

        data = self._fetch()
        if data is None:
            return False, "could not fetch CVE data"

        r = run_cmd(["pacman", "-Q"], log_failure=False)
        installed: Dict[str, str] = {}
        for line in r.stdout_lines:
            parts = line.split(" ", 1)
            if len(parts) == 2:
                installed[parts[0]] = parts[1].strip()

        vulnerable: List[Dict] = []
        for adv in data:
            pkg   = adv.get("package", "")
            fixed = adv.get("fixed")
            if pkg not in installed:
                continue
            if not fixed:
                vulnerable.append(adv)
                continue
            if vercmp(installed[pkg], fixed) < 0:
                vulnerable.append(adv)

        report = []
        for adv in vulnerable:
            sev  = adv.get("severity", "unknown")
            name = adv.get("package", "?")
            aid  = adv.get("advisory", "?")
            typ  = adv.get("type", "?")
