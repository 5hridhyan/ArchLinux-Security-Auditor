class Firewall(Module):
    info = ModInfo(
        name="firewall", kind=ModKind.FIREWALL,
        desc="nftables firewall (profiles: workstation/server/paranoid/strict)",
        version="4.0.0", author="archguard",
        deps=["nftables"], conflicts=["ufw"],
        reversible=True, risk="medium",
    )

    def pre_check(self, force=False, install_deps=False):
        ok, msg = super().pre_check(force, install_deps)
        if not ok:
            return ok, msg
        for svc in ("docker", "libvirtd", "lxd"):
            r = run_cmd(["systemctl", "is-active", svc], log_failure=False)
            if r.ok and r.stdout.strip() == "active":
                if not force:
                    return False, (
                        f"{svc!r} is active – nftables flush will drop its rules. "
                        "Use --force to override."
                    )
                log_action(self.info.name, f"{svc!r} active – rules will be replaced",
                           "warning", self.quiet, self.no_color)
        return True, "ok"

    def gen_config(self, profile: str = "workstation", **_) -> Dict[str, str]:
        ts = datetime.now().strftime("%Y-%m-%d %H:%M")
        if profile == "strict":
            return {"/etc/nftables.conf": _NFT_STRICT.format(ts=ts)}
        middle = _NFT_PROFILES.get(profile, _NFT_PROFILES["workstation"])
        conf = _NFT_HEAD.format(profile=profile, ts=ts) + middle + _NFT_TAIL
        return {"/etc/nftables.conf": conf}

    def apply(self, dry=False, force=False, verify=False, **kw):
        profile = kw.get("profile", "workstation")
        if profile == "strict" and not force and not dry:
            return False, "strict profile is high-risk – pass --force to confirm"
        ok, msg = super().apply(dry, force, verify, **kw)
        if ok and not dry:
            run_cmd(["systemctl", "enable", "nftables"],
                    module=self.info.name, quiet=self.quiet, no_color=self.no_color)
            r = run_cmd(["systemctl", "restart", "nftables"],
                        module=self.info.name, quiet=self.quiet, no_color=self.no_color)
            if not r.ok:
                return False, "nftables restart failed – check /etc/nftables.conf syntax"
            log_action(self.info.name, "nftables enabled and restarted",
                       quiet=self.quiet, no_color=self.no_color)
        return ok, msg

    def status(self) -> ModStatus:
        r = run_cmd(["systemctl", "is-active", "nftables"], log_failure=False)
        if r.ok and r.stdout.strip() == "active":
            return ModStatus.APPLIED
        r2 = run_cmd(["nft", "list", "ruleset"], log_failure=False)
        if r2.ok and r2.stdout.strip():
            return ModStatus.PARTIAL
        return ModStatus.UNKNOWN

    def verify(self):
        r = run_cmd(["nft", "list", "ruleset"],
                    module=self.info.name, quiet=self.quiet, no_color=self.no_color)
        if not r.ok:
            return False, "nftables not running or nft command failed"
        if "# archguard" not in r.stdout:
            return False, "archguard marker absent – ruleset may have been replaced"
        return True, "ok"


#  HARDENING MODULE: APPARMOR

class AppArmor(Module):
    info = ModInfo(
        name="apparmor", kind=ModKind.MAC,
        desc="AppArmor MAC – enforce profiles + inject kernel boot parameters",
        version="4.0.0", author="archguard",
        deps=["apparmor"], conflicts=[],
        reversible=True, risk="high",
    )

    def pre_check(self, force=False, install_deps=False):
        ok, msg = super().pre_check(force, install_deps)
        if not ok:
            return ok, msg
        if not Path("/sys/kernel/security/apparmor").exists():
            return False, "kernel lacks CONFIG_SECURITY_APPARMOR"
        if not run_cmd(["systemctl", "cat", "apparmor.service"], log_failure=False).ok:
            return False, "apparmor.service not found – is the package installed correctly?"
        return True, "ok"

    def gen_config(self, **_) -> Dict[str, str]:
        configs: Dict[str, str] = {}

        # parser.conf
        parser = "/etc/apparmor/parser.conf"
        try:
            cur = Path(parser).read_text() if Path(parser).exists() else ""
        except OSError as exc:
            log_action(self.info.name, f"cannot read {parser}: {exc}",
                       "warning", self.quiet, self.no_color)
            cur = ""

        needed = ['AA_ENABLED="yes"', 'APPARMOR_PROFILE_MODE="enforce"', 'WRITE_CACHE="yes"']
        new = cur
        for line in needed:
            if line not in new:
                new += line + "\n"
        if new != cur:
            configs[parser] = new

        # GRUB cmdline
        bl, _ = detect_bootloader()
        if bl == "grub":
            grub = "/etc/default/grub"
            try:
                g = Path(grub).read_text() if Path(grub).exists() else ""
            except OSError as exc:
                log_action(self.info.name, f"cannot read {grub}: {exc}",
                           "warning", self.quiet, self.no_color)
                g = ""
            if g and "GRUB_CMDLINE_LINUX_DEFAULT" in g:
                def _inject(m: re.Match) -> str:
                    line = m.group(0)
                    if "apparmor=1" not in line:
                        line = line.rstrip('"') + ' apparmor=1 security=apparmor"'
                    return line
                new_g = re.sub(r'GRUB_CMDLINE_LINUX_DEFAULT="[^"]*"', _inject, g)
                if new_g != g:
                    configs[grub] = new_g
        elif bl == "systemd-boot":
            log_action(self.info.name,
                       "systemd-boot: manually add 'apparmor=1 security=apparmor' to kernel cmdline",
                       "warning", self.quiet, self.no_color)
        else:
            log_action(self.info.name,
                       "unknown bootloader – add apparmor kernel params manually",
                       "warning", self.quiet, self.no_color)

        return configs

    def apply(self, dry=False, force=False, verify=False, **kw):
        ok, msg = super().apply(dry, force, verify, **kw)
        if ok and not dry:
            run_cmd(["systemctl", "enable", "--now", "apparmor"],
                    module=self.info.name, quiet=self.quiet, no_color=self.no_color)

            aa_enforce = shutil.which("aa-enforce")
            if aa_enforce:
                common = ["usr.bin.firefox", "usr.bin.chromium", "usr.bin.ssh",
                          "usr.sbin.cupsd", "usr.bin.evince", "usr.bin.thunderbird"]
                for prof in common:
                    p = Path("/etc/apparmor.d") / prof
                    if p.exists():
                        run_cmd([aa_enforce, str(p)], log_failure=False)
            else:
                log_action(self.info.name,
                           "aa-enforce not found – install apparmor-utils to enforce profiles",
                           "warning", self.quiet, self.no_color)

            if any(c["path"] == "/etc/default/grub"
                   for c in self.state.get(self.info.name)):
                r = run_cmd(["grub-mkconfig", "-o", "/boot/grub/grub.cfg"],
                            module=self.info.name, quiet=self.quiet,
                            no_color=self.no_color, timeout=60)
                if not r.ok:
                    return False, "grub-mkconfig failed"
                log_action(self.info.name, "⚠ reboot required for AppArmor kernel parameters",
                           "warning", self.quiet, self.no_color)
        return ok, msg

    def status(self):
        r = run_cmd(["aa-status", "--enabled"], log_failure=False)
        return ModStatus.APPLIED if r.ok else ModStatus.UNKNOWN

    def verify(self):
        r = run_cmd(["aa-status", "--enabled"], log_failure=False)
        return (True, "ok") if r.ok else (False, "AppArmor not enabled in kernel")


