            subprocess.run(["aide", "--init"], check=False)
            shutil.move("/var/lib/aide/aide.db.new.gz", "/var/lib/aide/aide.db.gz")
            log_action(self.info.name, "AIDE database initialized", quiet=self.quiet, no_color=self.no_color)
        else:
            log_action(self.info.name, "AIDE database already exists", quiet=self.quiet, no_color=self.no_color)

        return True, "aide configured"

    def verify(self) -> Tuple[bool, str]:
        # Run integrity check
        result = subprocess.run(["aide", "--check"], capture_output=True, text=True)
        if result.returncode != 0:
            log_action(self.info.name, "AIDE detected file changes:", "warning", quiet=self.quiet, no_color=self.no_color)
            for line in result.stdout.splitlines():
                if "changed" in line or "added" in line or "removed" in line:
                    print(f"  {line}")
            return False, "changes detected"
        log_action(self.info.name, "AIDE integrity check passed", quiet=self.quiet, no_color=self.no_color)
        return True, "integrity ok"

